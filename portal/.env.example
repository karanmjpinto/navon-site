# Copy to .env.local for local development. Never commit .env.local.
#
# Railway production: set these in the Railway dashboard under the portal service.
# DATABASE_URL is injected automatically when the Postgres service is linked.

# ── Database ────────────────────────────────────────────────────────────────
# Local dev: docker compose up, or local Postgres 17 + TimescaleDB
# Railway:   auto-injected by linking the navon-postgres service
DATABASE_URL=postgres://navon:navon@localhost:5432/navon_portal

# ── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-me

# Canonical URL — must match the public domain exactly (no trailing slash).
# Local:   http://localhost:3002
# Railway: https://portal.navon.africa
AUTH_URL=http://localhost:3002

# ── Email (magic link + password reset via Resend) ──────────────────────────
AUTH_RESEND_KEY=re_...
EMAIL_FROM="Navon <noreply@navon.africa>"

# ── File uploads ─────────────────────────────────────────────────────────────
# Railway filesystem is ephemeral — attach a Railway Volume and set this to
# its mount path (e.g. /mnt/uploads) before enabling attachment features.
# Dev default (./uploads) is fine locally.
UPLOAD_DIR=./uploads

# ── M-Pesa Daraja (Phase 2 — leave empty for stub flow) ──────────────────────
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=https://portal.navon.africa/api/payments/mpesa/callback
DARAJA_SANDBOX=true

# ── SAML SSO (Phase 2 — leave empty until first university customer) ──────────
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_CERT=
# SAML_SP_ENTITY_ID=   # defaults to AUTH_URL/api/auth/saml/metadata
SAML_WANT_ASSERTIONS_SIGNED=true

# ── NetBox federation (sync worker) ─────────────────────────────────────────
# Local dev: docker compose -f docker-compose.dev.yml up → http://localhost:8000
# Leave empty to disable the cron worker on Railway until NetBox is reachable.
NETBOX_URL=
NETBOX_TOKEN=
NETBOX_WEBHOOK_SECRET=
