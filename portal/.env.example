# Copy to .env.local for development. Never commit .env.local.

# Postgres (local dev: docker compose up, or local install with timescaledb)
DATABASE_URL=postgres://navon:navon@localhost:5432/navon_portal

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# Auth.js URL — needed in production behind Caddy
AUTH_URL=http://localhost:3002

# Email (magic link delivery via Resend)
AUTH_RESEND_KEY=
EMAIL_FROM="Navon <noreply@navonworld.com>"

# M-Pesa Daraja (Phase 2; leave empty for the stub flow)
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=https://portal.navonworld.com/api/payments/mpesa/callback
