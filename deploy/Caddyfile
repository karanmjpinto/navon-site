# Caddy 2 config for the Navon GPU box.
# Apex serves the existing static marketing site; portal subdomain proxies the Next.js app.
# TLS via Let's Encrypt is automatic; just point both A records at the box.

{
	email ops@navonworld.com
	# Uncomment to harden:
	# auto_https disable_redirects
}

navonworld.com, www.navonworld.com {
	root * /var/www/navon-site
	encode gzip zstd
	file_server
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
	}
}

portal.navonworld.com {
	encode gzip zstd
	reverse_proxy 127.0.0.1:3002

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
		# Next.js sets its own Content-Security-Policy where appropriate.
	}
}
