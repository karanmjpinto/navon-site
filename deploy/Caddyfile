# Caddy 2 config for the Navon GPU box.
# Apex serves the existing static marketing site; portal subdomain proxies the Next.js app.
# TLS via Let's Encrypt is automatic; just point both A records at the box.

{
	email ops@navonworld.com
	acme_dns godaddy {env.GODADDY_API_KEY}:{env.GODADDY_API_SECRET}
	# Use GoDaddy's own nameservers to verify TXT propagation before
	# signalling Let's Encrypt — GoDaddy can take ~30s to propagate.
	resolvers ns25.domaincontrol.com:53 ns26.domaincontrol.com:53
}

portal.navonworld.com {
	encode gzip zstd
	reverse_proxy portal:3002

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
	}
}
