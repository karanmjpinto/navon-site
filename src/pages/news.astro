---
import Site from '../layouts/Site.astro';
import '../styles/news.css';

// News items, newest first. Add `href` to link an item out to its source;
// items without an href render without a "Read" link (no source yet).
const news = [
  {
    my: 'JUN 2026', day: '08', dow: 'MON',
    tag: 'Milestone',
    title: "Navon selected by the Digital Investment Facility to build Kenya's first sovereign, green data centre.",
    desc: "Navon will receive tailored technical assistance from the Digital Investment Facility (DIF) — backed by the European Commission, Germany and Finland under the Team Europe D4D Hub — to build a 0.8MW sovereign and green data centre in Hells Gate Deep Tech Park, serving Kenyan businesses, research institutions, and the health, finance and agriculture sectors.",
    href: 'https://www.linkedin.com/posts/d4dhub_hell-dif-dif-activity-7469644615499800576-Bod1',
  },
  {
    my: 'OCT 2025', day: '20', dow: 'MON',
    tag: 'Partnership',
    title: 'Navon and Sytronix sign strategic hardware partnership.',
    desc: 'A partnership focused on delivering improved value for modular co-location customers through right-fit compute systems — closing the gap between the rack and the workload.',
  },
  {
    my: 'OCT 2025', day: '14', dow: 'TUE',
    tag: 'Strategic agreement',
    title: 'Navon and Africa Compute Fund sign strategic agreement.',
    desc: 'Joint deployment of sovereign AI infrastructure beginning with the Nairobi Supercluster, with structured opportunities for additional compute participants to join.',
  },
  {
    my: 'AUG 2025', day: '08', dow: 'FRI',
    tag: 'MOU',
    title: 'Navon and Alliance4AI sign MOU to advance responsible AI and quantum tech in Africa.',
    desc: 'An agreement to accelerate responsible AI and quantum technology innovation across the African continent — pairing Navon infrastructure with Alliance4AI policy and ecosystem reach.',
  },
  {
    my: 'JUL 2025', day: '21', dow: 'MON',
    tag: 'MOU',
    title: 'Navon and Siscom Technology sign MOU.',
    desc: 'An agreement to jointly build AI infrastructure and expand modular data centre investment access to broader public audiences across the region.',
  },
  {
    my: 'JUL 2025', day: '18', dow: 'FRI',
    tag: 'University partnership',
    title: 'Strathmore University and Navon sign MOU.',
    desc: 'A partnership to collaborate on digital infrastructure, education, and innovation — supporting students and researchers in Kenya with sovereign compute and on-site placements.',
  },
  {
    my: 'JUN 2025', day: '25', dow: 'WED',
    tag: 'Speaking',
    title: 'Navon at Blue Beach: rethinking data centre infrastructure.',
    desc: 'Navon advocates for European policymakers to prioritise renewable power sources over legacy fibre corridors when planning the next generation of digital sovereignty.',
  },
];
---
<Site
  title="News — Navon"
  description="Partnerships, milestones, and what's happening at Navon."
>

<!-- Page hero -->
<section class="page-hero">
  <div class="page-hero-inner">
    <div>
      <div class="eyebrow"><span class="mark"></span>News</div>
      <h1 class="page-title reveal">Partnerships,<br/>milestones,<br/><span class="accent">moves on the ground.</span></h1>
      <p class="page-lede reveal d1" style="margin-top:24px;">
        Strategic agreements, MOUs, and what's happening at Navon. Updated as we sign.
      </p>
    </div>
    <svg class="hero-glyph tech draw" viewBox="0 0 460 380" aria-hidden="true">
      <!-- abstract: nodes connecting -->
      <g class="hair">
        <circle cx="80" cy="90" r="14" fill="none"/>
        <circle cx="80" cy="200" r="14" fill="none"/>
        <circle cx="80" cy="310" r="14" fill="none"/>
        <circle cx="380" cy="120" r="14" fill="none"/>
        <circle cx="380" cy="240" r="14" fill="none"/>
      </g>
      <g class="signal d2" stroke-width="1.2" fill="none">
        <line x1="94" y1="90" x2="366" y2="120"/>
        <line x1="94" y1="200" x2="366" y2="120"/>
        <line x1="94" y1="200" x2="366" y2="240"/>
        <line x1="94" y1="310" x2="366" y2="240"/>
      </g>
      <circle cx="80" cy="90" r="5" class="signal"/>
      <circle cx="80" cy="200" r="5" class="signal"/>
      <circle cx="80" cy="310" r="5" class="signal"/>
      <circle cx="380" cy="120" r="6" class="signal"/>
      <circle cx="380" cy="120" r="9" class="signal pulse" opacity="0.4"/>
      <circle cx="380" cy="240" r="6" class="signal"/>
      <text x="60" y="358" font-size="10" letter-spacing="2" fill="#9E9F9B" font-family="JetBrains Mono">PARTNERSHIPS · 2025</text>
    </svg>
  </div>
</section>

<!-- News list -->
<section class="news-list">
  {news.map((item, i) => {
    const Tag = item.href ? 'a' : 'article';
    const classes = ['news-item', 'reveal'];
    if (i) classes.push(`d${i}`);
    if (!item.href) classes.push('news-item--static');
    const linkAttrs = item.href
      ? { href: item.href, target: '_blank', rel: 'noopener noreferrer' }
      : {};
    return (
      <Tag class={classes.join(' ')} {...linkAttrs}>
        <div class="news-date">
          <span class="my">{item.my}</span>
          <span class="day">{item.day}</span>
          <span class="my">{item.dow}</span>
        </div>
        <div>
          <div class="news-tag">{item.tag}</div>
          <h2 class="news-title">{item.title}</h2>
          <p class="news-desc">{item.desc}</p>
        </div>
        {item.href && <div class="news-cta">Read <span class="arrow">→</span></div>}
      </Tag>
    );
  })}
</section>

<!-- Newsletter -->
<section class="signup">
  <div class="signup-inner">
    <div>
      <div class="eyebrow"><span class="mark"></span>Stay close</div>
      <h2 class="reveal">Get Navon news<br/>as <span class="accent">it lands.</span></h2>
    </div>
    <div class="reveal d1">
      <p style="color:var(--light); font-size:16px; line-height:1.55; max-width:46ch; margin: 0 0 24px;">
        Partnerships, site milestones, and quarterly updates from Hells Gate and beyond. No marketing churn — about one email a month.
      </p>
      <form class="signup-form" onsubmit="event.preventDefault(); this.querySelector('input').value=''; this.querySelector('input').placeholder='Thanks — you\u0027re on the list.';">
        <input type="email" placeholder="you@org.com" required>
        <button type="submit">Subscribe</button>
      </form>
      <div class="signup-note">No spam. Unsubscribe in one click.</div>
    </div>
  </div>
</section>

<!-- Footer -->
</Site>
