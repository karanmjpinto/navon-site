---
import Site from '../layouts/Site.astro';
import '../styles/news.css';
---
<Site
  title="News — Navon"
  description="Partnerships, milestones, and what's happening at Navon."
>

<!-- Page hero -->
<section class="page-hero">
  <div class="page-hero-inner">
    <div>
      <div class="eyebrow"><span class="mark"></span>News</div>
      <h1 class="page-title reveal">Partnerships,<br/>milestones,<br/><span class="accent">moves on the ground.</span></h1>
      <p class="page-lede reveal d1" style="margin-top:24px;">
        Strategic agreements, MOUs, and what's happening at Navon. Updated as we sign.
      </p>
    </div>
    <svg class="hero-glyph tech draw" viewBox="0 0 460 380" aria-hidden="true">
      <!-- abstract: nodes connecting -->
      <g class="hair">
        <circle cx="80" cy="90" r="14" fill="none"/>
        <circle cx="80" cy="200" r="14" fill="none"/>
        <circle cx="80" cy="310" r="14" fill="none"/>
        <circle cx="380" cy="120" r="14" fill="none"/>
        <circle cx="380" cy="240" r="14" fill="none"/>
      </g>
      <g class="signal d2" stroke-width="1.2" fill="none">
        <line x1="94" y1="90" x2="366" y2="120"/>
        <line x1="94" y1="200" x2="366" y2="120"/>
        <line x1="94" y1="200" x2="366" y2="240"/>
        <line x1="94" y1="310" x2="366" y2="240"/>
      </g>
      <circle cx="80" cy="90" r="5" class="signal"/>
      <circle cx="80" cy="200" r="5" class="signal"/>
      <circle cx="80" cy="310" r="5" class="signal"/>
      <circle cx="380" cy="120" r="6" class="signal"/>
      <circle cx="380" cy="120" r="9" class="signal pulse" opacity="0.4"/>
      <circle cx="380" cy="240" r="6" class="signal"/>
      <text x="60" y="358" font-size="10" letter-spacing="2" fill="#9E9F9B" font-family="JetBrains Mono">PARTNERSHIPS · 2025</text>
    </svg>
  </div>
</section>

<!-- News list -->
<section class="news-list">
  <article class="news-item reveal">
    <div class="news-date">
      <span class="my">OCT 2025</span>
      <span class="day">20</span>
      <span class="my">MON</span>
    </div>
    <div>
      <div class="news-tag">Partnership</div>
      <h2 class="news-title">Navon and Sytronix sign strategic hardware partnership.</h2>
      <p class="news-desc">A partnership focused on delivering improved value for modular co-location customers through right-fit compute systems — closing the gap between the rack and the workload.</p>
    </div>
    <div class="news-cta">Read <span class="arrow">→</span></div>
  </article>

  <article class="news-item reveal d1">
    <div class="news-date">
      <span class="my">OCT 2025</span>
      <span class="day">14</span>
      <span class="my">TUE</span>
    </div>
    <div>
      <div class="news-tag">Strategic agreement</div>
      <h2 class="news-title">Navon and Africa Compute Fund sign strategic agreement.</h2>
      <p class="news-desc">Joint deployment of sovereign AI infrastructure beginning with the Nairobi Supercluster, with structured opportunities for additional compute participants to join.</p>
    </div>
    <div class="news-cta">Read <span class="arrow">→</span></div>
  </article>

  <article class="news-item reveal d2">
    <div class="news-date">
      <span class="my">AUG 2025</span>
      <span class="day">08</span>
      <span class="my">FRI</span>
    </div>
    <div>
      <div class="news-tag">MOU</div>
      <h2 class="news-title">Navon and Alliance4AI sign MOU to advance responsible AI and quantum tech in Africa.</h2>
      <p class="news-desc">An agreement to accelerate responsible AI and quantum technology innovation across the African continent — pairing Navon infrastructure with Alliance4AI policy and ecosystem reach.</p>
    </div>
    <div class="news-cta">Read <span class="arrow">→</span></div>
  </article>

  <article class="news-item reveal d3">
    <div class="news-date">
      <span class="my">JUL 2025</span>
      <span class="day">21</span>
      <span class="my">MON</span>
    </div>
    <div>
      <div class="news-tag">MOU</div>
      <h2 class="news-title">Navon and Siscom Technology sign MOU.</h2>
      <p class="news-desc">An agreement to jointly build AI infrastructure and expand modular data centre investment access to broader public audiences across the region.</p>
    </div>
    <div class="news-cta">Read <span class="arrow">→</span></div>
  </article>

  <article class="news-item reveal d4">
    <div class="news-date">
      <span class="my">JUL 2025</span>
      <span class="day">18</span>
      <span class="my">FRI</span>
    </div>
    <div>
      <div class="news-tag">University partnership</div>
      <h2 class="news-title">Strathmore University and Navon sign MOU.</h2>
      <p class="news-desc">A partnership to collaborate on digital infrastructure, education, and innovation — supporting students and researchers in Kenya with sovereign compute and on-site placements.</p>
    </div>
    <div class="news-cta">Read <span class="arrow">→</span></div>
  </article>

  <article class="news-item reveal d5">
    <div class="news-date">
      <span class="my">JUN 2025</span>
      <span class="day">25</span>
      <span class="my">WED</span>
    </div>
    <div>
      <div class="news-tag">Speaking</div>
      <h2 class="news-title">Navon at Blue Beach: rethinking data centre infrastructure.</h2>
      <p class="news-desc">Navon advocates for European policymakers to prioritise renewable power sources over legacy fibre corridors when planning the next generation of digital sovereignty.</p>
    </div>
    <div class="news-cta">Read <span class="arrow">→</span></div>
  </article>
</section>

<!-- Newsletter -->
<section class="signup">
  <div class="signup-inner">
    <div>
      <div class="eyebrow"><span class="mark"></span>Stay close</div>
      <h2 class="reveal">Get Navon news<br/>as <span class="accent">it lands.</span></h2>
    </div>
    <div class="reveal d1">
      <p style="color:var(--light); font-size:16px; line-height:1.55; max-width:46ch; margin: 0 0 24px;">
        Partnerships, site milestones, and quarterly updates from Hells Gate and beyond. No marketing churn — about one email a month.
      </p>
      <form class="signup-form" onsubmit="event.preventDefault(); this.querySelector('input').value=''; this.querySelector('input').placeholder='Thanks — you\u0027re on the list.';">
        <input type="email" placeholder="you@org.com" required>
        <button type="submit">Subscribe</button>
      </form>
      <div class="signup-note">No spam. Unsubscribe in one click.</div>
    </div>
  </div>
</section>

<!-- Footer -->
</Site>
