---
import Site from '../layouts/Site.astro';
import '../styles/news.css';
import { news } from '../data/news.js';
---
<Site
  title="News — Navon"
  description="Partnerships, milestones, and what's happening at Navon."
>

<!-- Page hero -->
<section class="page-hero">
  <div class="page-hero-inner">
    <div>
      <div class="eyebrow"><span class="mark"></span>News</div>
      <h1 class="page-title reveal">Partnerships,<br/>milestones,<br/><span class="accent">moves on the ground.</span></h1>
      <p class="page-lede reveal d1" style="margin-top:24px;">
        Strategic agreements, MOUs, and what's happening at Navon. Updated as we sign.
      </p>
    </div>
    <svg class="hero-glyph tech draw" viewBox="0 0 460 380" aria-hidden="true">
      <!-- abstract: nodes connecting -->
      <g class="hair">
        <circle cx="80" cy="90" r="14" fill="none"/>
        <circle cx="80" cy="200" r="14" fill="none"/>
        <circle cx="80" cy="310" r="14" fill="none"/>
        <circle cx="380" cy="120" r="14" fill="none"/>
        <circle cx="380" cy="240" r="14" fill="none"/>
      </g>
      <g class="signal d2" stroke-width="1.2" fill="none">
        <line x1="94" y1="90" x2="366" y2="120"/>
        <line x1="94" y1="200" x2="366" y2="120"/>
        <line x1="94" y1="200" x2="366" y2="240"/>
        <line x1="94" y1="310" x2="366" y2="240"/>
      </g>
      <circle cx="80" cy="90" r="5" class="signal"/>
      <circle cx="80" cy="200" r="5" class="signal"/>
      <circle cx="80" cy="310" r="5" class="signal"/>
      <circle cx="380" cy="120" r="6" class="signal"/>
      <circle cx="380" cy="120" r="9" class="signal pulse" opacity="0.4"/>
      <circle cx="380" cy="240" r="6" class="signal"/>
      <text x="60" y="358" font-size="10" letter-spacing="2" fill="#9E9F9B" font-family="JetBrains Mono">PARTNERSHIPS · 2025</text>
    </svg>
  </div>
</section>

<!-- News list -->
<section class="news-list">
  {news.map((item, i) => {
    // body → on-site article (same tab); external → source link (new tab).
    const internal = item.body ? `/news/${item.slug}.html` : null;
    const link = internal ?? item.external ?? null;
    const isExternal = !internal && !!item.external;
    const Tag = link ? 'a' : 'article';
    const classes = ['news-item', 'reveal'];
    if (i) classes.push(`d${i}`);
    if (!link) classes.push('news-item--static');
    const linkAttrs = link
      ? (isExternal
          ? { href: link, target: '_blank', rel: 'noopener noreferrer' }
          : { href: link })
      : {};
    return (
      <Tag class={classes.join(' ')} {...linkAttrs}>
        <div class="news-date">
          <span class="my">{item.my}</span>
          <span class="day">{item.day}</span>
          <span class="my">{item.dow}</span>
        </div>
        <div>
          <div class="news-tag">{item.tag}</div>
          <h2 class="news-title">{item.title}</h2>
          <p class="news-desc">{item.desc}</p>
        </div>
        {link && (
          <div class="news-cta">Read {isExternal ? <span class="arrow">↗</span> : <span class="arrow">→</span>}</div>
        )}
      </Tag>
    );
  })}
</section>

<!-- Newsletter -->
<section class="signup">
  <div class="signup-inner">
    <div>
      <div class="eyebrow"><span class="mark"></span>Stay close</div>
      <h2 class="reveal">Get Navon news<br/>as <span class="accent">it lands.</span></h2>
    </div>
    <div class="reveal d1">
      <p style="color:var(--light); font-size:16px; line-height:1.55; max-width:46ch; margin: 0 0 24px;">
        Partnerships, site milestones, and quarterly updates from Hells Gate and beyond. No marketing churn — about one email a month.
      </p>
      <form class="signup-form" onsubmit="event.preventDefault(); this.querySelector('input').value=''; this.querySelector('input').placeholder='Thanks — you\u0027re on the list.';">
        <input type="email" placeholder="you@org.com" required>
        <button type="submit">Subscribe</button>
      </form>
      <div class="signup-note">No spam. Unsubscribe in one click.</div>
    </div>
  </div>
</section>

<!-- Footer -->
</Site>
