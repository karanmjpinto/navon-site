  <script is:inline>
    /* trigger strikethrough animation when positioning headline enters */
    const posH = document.querySelector('.positioning-headline');
    if (posH) {
      const posIo = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            posIo.unobserve(e.target);
          }
        });
      }, { threshold: 0.3 });
      posIo.observe(posH);
    }

    /* partners carousel arrows */
    const pRail = document.getElementById('partnersRail');
    if (pRail) {
      document.querySelectorAll('.lp-arrow').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = Number(btn.getAttribute('data-dir')) || 1;
          const card = pRail.querySelector('.lp-card');
          const step = card ? card.offsetWidth + 24 : 360;
          pRail.scrollBy({ left: dir * step, behavior: 'smooth' });
        });
      });
    }

    /* ramp curve draw-in when it enters viewport */
    const ramp = document.querySelector('.ramp');
    if (ramp) {
      const rampIo = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            rampIo.unobserve(e.target);
          }
        });
      }, { threshold: 0.25 });
      rampIo.observe(ramp);
    }
  </script>

