---
import Site from '../layouts/Site.astro';
import '../styles/index.css';
---
<Site
  title="Navon — Sovereign compute, powered by the earth"
  description="Navon builds vertically integrated deep tech parks in emerging markets. Modular data centres, sovereign cloud, applications, and ecosystems. Sited where the energy is clean and local."
>

  <!-- ── HERO ────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-content">
      <div class="eyebrow"><span class="mark"></span>Deep tech · for the Global South</div>
      <h1 class="hero-headline" data-stagger>
        <span class="hl"><span>Sovereign</span></span>
        <span class="hl"><span>compute,</span></span>
        <span class="hl accent"><span>powered by</span></span>
        <span class="hl accent"><span>the earth.</span></span>
      </h1>
      <p class="hero-sub">
        We build and run vertically integrated deep tech parks: modular
        infrastructure, sovereign cloud, applications, ecosystems. We site
        them where the energy is clean and local.
      </p>
      <div class="hero-ctas">
        <button class="cta">Explore Hells Gate <span class="arrow">→</span></button>
        <button class="cta-ghost">See the stack <span class="arrow">↓</span></button>
      </div>
    </div>

    <!-- Hero visual: axonometric cutaway of a 400 kW modular pod -->
    <div class="hero-visual" aria-hidden="true">
      <svg viewBox="0 0 580 480" class="tech draw">
        <!-- top dimension -->
        <g class="thin">
          <line x1="110" y1="60" x2="490" y2="60"/>
          <line x1="110" y1="54" x2="110" y2="66"/>
          <line x1="490" y1="54" x2="490" y2="66"/>
        </g>
        <text x="300" y="54" text-anchor="middle" font-size="10" letter-spacing="2">12.2 M</text>

        <!-- back face -->
        <polygon class="hair d2" points="190,118 450,118 450,284 190,284"/>
        <!-- front face (axon offset) -->
        <polygon class="line d2" points="110,160 370,160 370,320 110,320"/>
        <!-- depth lines -->
        <g class="dashed d3">
          <line x1="190" y1="118" x2="110" y2="160"/>
          <line x1="450" y1="118" x2="370" y2="160"/>
          <line x1="450" y1="284" x2="370" y2="320"/>
          <line x1="190" y1="284" x2="110" y2="320"/>
        </g>

        <!-- rack shelves (cutaway) -->
        <g class="hair d3">
          <line x1="140" y1="180" x2="340" y2="180"/>
          <line x1="140" y1="200" x2="340" y2="200"/>
          <line x1="140" y1="220" x2="340" y2="220"/>
          <line x1="140" y1="240" x2="340" y2="240"/>
          <line x1="140" y1="260" x2="340" y2="260"/>
          <line x1="140" y1="280" x2="340" y2="280"/>
          <line x1="140" y1="300" x2="340" y2="300"/>
          <line x1="175" y1="172" x2="175" y2="308"/>
          <line x1="240" y1="172" x2="240" y2="308"/>
          <line x1="305" y1="172" x2="305" y2="308"/>
        </g>

        <!-- active GPU block -->
        <rect x="242" y="202" width="61" height="18" class="signal" opacity="0.85"/>
        <rect x="242" y="202" width="61" height="18" fill="none" stroke="#E7FF00" stroke-width="1"/>

        <!-- callout -->
        <g class="signal d4" stroke-width="0.8" fill="none">
          <polyline points="303,211 432,211 462,178"/>
        </g>
        <text x="470" y="170" font-size="10" class="label-signal" letter-spacing="1.5">RACK 02 / U18</text>
        <text x="470" y="184" font-size="9" letter-spacing="1.5">8× GPU · 20 KW</text>

        <!-- power feed from bottom-left -->
        <g class="line d4">
          <polyline points="40,420 80,420 80,340 110,340"/>
        </g>
        <circle cx="40" cy="420" r="4" class="signal"/>
        <circle cx="40" cy="420" r="6" class="signal pulse" opacity="0.4"/>
        <text x="50" y="440" font-size="9" letter-spacing="1.5">GEOTHERMAL · 220 KV</text>

        <!-- dimension bottom -->
        <g class="thin d4">
          <line x1="110" y1="350" x2="370" y2="350"/>
          <line x1="110" y1="344" x2="110" y2="356"/>
          <line x1="370" y1="344" x2="370" y2="356"/>
        </g>
        <text x="240" y="370" text-anchor="middle" font-size="10" letter-spacing="2">POD A-01 · 400 KW</text>
      </svg>
    </div>

    <div class="hero-meta">
      <div class="m">Clean energy <span class="v">95%</span></div>
      <div class="m">PUE <span class="v">1.29</span></div>
      <div class="m">Rack density <span class="v">20 kW+</span></div>
      <div class="m">Redundancy <span class="v">Tier III</span></div>
    </div>
  </section>

  <!-- ── TRUST STRIP ─────────────────────────────── -->
  <section class="trust">
    <div class="trust-label mono">Partners and collaborators ↓</div>
    <div class="marquee" aria-hidden="true">
      <span class="logo">NVIDIA</span>
      <span class="logo">Delta Electronics</span>
      <span class="logo">Atlancis</span>
      <span class="logo">Sytronix</span>
      <span class="logo">Pure Infrastructure</span>
      <span class="logo">Hoptroff</span>
      <span class="logo">Asterfusion</span>
      <span class="logo">AI Kenya</span>
      <span class="logo">Alliance for AI</span>
      <span class="logo">QCentroid</span>
      <span class="logo">ExeQuantum</span>
      <span class="logo">ID Quantique</span>
      <span class="logo">MAST Energy Developments</span>
      <span class="logo">Hosted.ai</span>
      <span class="logo">UCL</span>
      <span class="logo">ETH Zurich</span>
      <span class="logo">Strathmore University</span>
      <span class="logo">Siscom</span>
      <span class="logo">Safaricom</span>
      <!-- duplicate for seamless scroll -->
      <span class="logo">NVIDIA</span>
      <span class="logo">Delta Electronics</span>
      <span class="logo">Atlancis</span>
      <span class="logo">Sytronix</span>
      <span class="logo">Pure Infrastructure</span>
      <span class="logo">Hoptroff</span>
      <span class="logo">Asterfusion</span>
      <span class="logo">AI Kenya</span>
      <span class="logo">Alliance for AI</span>
      <span class="logo">QCentroid</span>
      <span class="logo">ExeQuantum</span>
      <span class="logo">ID Quantique</span>
      <span class="logo">MAST Energy Developments</span>
      <span class="logo">Hosted.ai</span>
      <span class="logo">UCL</span>
      <span class="logo">ETH Zurich</span>
      <span class="logo">Strathmore University</span>
      <span class="logo">Siscom</span>
      <span class="logo">Safaricom</span>
    </div>
  </section>

  <!-- ── STACK ───────────────────────────────────── -->
  <section id="stack">
    <div class="section-head">
      <div>
        <div class="eyebrow"><span class="mark"></span>The platform</div>
        <h2 class="section-title reveal">Four pillars.<br/><span class="accent">One sovereign stack.</span></h2>
      </div>
      <p class="section-lede reveal d1">
        Hyperscale can be bought. Sovereignty has to be built. We integrate
        the full stack, from the slab the racks sit on through to the
        applications customers run on top, so the institutions we serve
        actually own their infrastructure.
      </p>
    </div>

    <div class="stack-grid section-inner" style="padding-top:0;">
      <article class="pillar reveal d1">
        <div class="pillar-num mono">01 / MODULAR INFRA</div>
        <h3 class="pillar-name">Foundational infrastructure</h3>
        <p class="pillar-desc">Factory-built 400 kW Tier III pods, 20 kW+ per rack. We separate the modular build from the civil works, so capacity lands in weeks rather than years.</p>
        <ul class="pillar-bullets">
          <li>Delta Electronics modular pods</li>
          <li>N+N power · N+1 cooling</li>
          <li>Dual-entry fibre, meet-me rooms</li>
        </ul>
        <div class="pillar-tag">Explore <span class="arrow">→</span></div>
      </article>

      <article class="pillar reveal d2">
        <div class="pillar-num mono">02 / SOFTWARE UTILITY</div>
        <h3 class="pillar-name">Private sovereign cloud</h3>
        <p class="pillar-desc">Cloud orchestration for compute and storage, with governance built into the platform. Your data lives on hardware we operate, inside your jurisdiction. The residency is physical, not contractual.</p>
        <ul class="pillar-bullets">
          <li>Kinesis + Hosted.ai orchestration</li>
          <li>GPU, HPC and NVMe storage fabric</li>
          <li>JupyterHub &amp; dev sandboxes</li>
        </ul>
        <div class="pillar-tag">Explore <span class="arrow">→</span></div>
      </article>

      <article class="pillar reveal d3">
        <div class="pillar-num mono">03 / APPLICATIONS</div>
        <h3 class="pillar-name">Platforms &amp; SDKs</h3>
        <p class="pillar-desc">Sector-ready platforms for governments, universities, and enterprises: sovereign AI, HPC simulation, climate and health informatics. Native inference, not a routing layer.</p>
        <ul class="pillar-bullets">
          <li>Sovereign AI / ML platforms</li>
          <li>Ollama, vLLM, OpenAI-compatible API</li>
          <li>HPC templates: climate, genomics, CFD</li>
          <li>Quantum sandbox via QCentroid</li>
        </ul>
        <div class="pillar-tag">Explore <span class="arrow">→</span></div>
      </article>

      <article class="pillar reveal d4">
        <div class="pillar-num mono">04 / ECOSYSTEMS</div>
        <h3 class="pillar-name">Talent &amp; knowledge</h3>
        <p class="pillar-desc">A network of universities, researchers and operators. Global expertise flows in through partners; local talent flows out through programmes and placements.</p>
        <ul class="pillar-bullets">
          <li>UCL · ETH · UPM · UPC partnerships</li>
          <li>On-site internships at Hells Gate</li>
          <li>Developer community &amp; hackathons</li>
        </ul>
        <div class="pillar-tag">Explore <span class="arrow">→</span></div>
      </article>
    </div>
  </section>

  <!-- ── HOW IT WORKS (interactive, fin.ai style) ── -->
  <section id="how">
    <div class="section-head">
      <div>
        <div class="eyebrow"><span class="mark"></span>How it works</div>
        <h2 class="section-title reveal">From substation<br/><span class="accent">to model serving.</span></h2>
      </div>
      <p class="section-lede reveal d1">
        Five steps, vertically integrated. Click through each layer to see what
        we own, what we build, and what that means for the workloads running
        on top. Owned. Not routed.
      </p>
    </div>

    <div class="flow">
      <div class="flow-wrap">
        <div class="flow-steps" role="tablist">
          <button class="flow-step active" data-step="1" role="tab" aria-selected="true">
            <div class="step-num">01 / SOURCE</div>
            <div class="step-name">Clean baseload</div>
            <p class="step-short">Geothermal, hydro, solar — secured at source.</p>
          </button>
          <button class="flow-step" data-step="2" role="tab" aria-selected="false">
            <div class="step-num">02 / GRID</div>
            <div class="step-name">Sovereign corridor</div>
            <p class="step-short">High-voltage transmission, carrier-neutral fibre.</p>
          </button>
          <button class="flow-step" data-step="3" role="tab" aria-selected="false">
            <div class="step-num">03 / MODULE</div>
            <div class="step-name">400 kW Tier III pod</div>
            <p class="step-short">Factory-built, delivered in weeks.</p>
          </button>
          <button class="flow-step" data-step="4" role="tab" aria-selected="false">
            <div class="step-num">04 / RACK</div>
            <div class="step-name">20 kW+ GPU rack</div>
            <p class="step-short">A+B redundant, dual-corded.</p>
          </button>
          <button class="flow-step" data-step="5" role="tab" aria-selected="false">
            <div class="step-num">05 / WORKLOAD</div>
            <div class="step-name">Sovereign AI &amp; HPC</div>
            <p class="step-short">Data resident, governance embedded.</p>
          </button>
        </div>

        <div class="flow-view">
          <div class="flow-canvas">

            <!-- Step 1: Source -->
            <div class="flow-panel active" data-panel="1">
              <svg viewBox="0 0 520 320" class="tech">
                <!-- earth cross-section -->
                <path class="line" d="M30 220 Q 260 180 490 220 L 490 290 L 30 290 Z"/>
                <path class="dashed" d="M30 240 Q 260 205 490 240"/>
                <path class="dashed" d="M30 260 Q 260 230 490 260"/>
                <!-- steam vent -->
                <g class="hair">
                  <path d="M260 220 C 258 180, 250 160, 260 140 C 270 120, 265 100, 260 80"/>
                  <path d="M250 210 C 248 180, 242 162, 250 142"/>
                  <path d="M270 210 C 272 182, 278 162, 270 142"/>
                </g>
                <!-- turbine -->
                <g class="line">
                  <rect x="340" y="170" width="90" height="50" fill="none"/>
                  <circle cx="385" cy="195" r="15" fill="none"/>
                  <line x1="385" y1="180" x2="385" y2="210"/>
                  <line x1="370" y1="195" x2="400" y2="195"/>
                </g>
                <text x="340" y="160" font-size="9" letter-spacing="1.5">TURBINE · 100 MW</text>
                <!-- steam to turbine -->
                <path class="dashed" d="M260 140 Q 300 140 340 180" />
                <!-- output line -->
                <g class="signal" stroke-width="1" fill="none">
                  <polyline points="430,195 470,195 470,100"/>
                </g>
                <circle cx="430" cy="195" r="3" class="signal"/>
                <circle cx="430" cy="195" r="5" class="signal pulse" opacity="0.4"/>
                <text x="470" y="92" text-anchor="middle" font-size="9" class="label-signal" letter-spacing="1.5">220 KV</text>
                <!-- labels -->
                <text x="40" y="280" font-size="9" letter-spacing="1.5">GEOTHERMAL RESERVOIR</text>
                <text x="40" y="50" font-size="10" letter-spacing="2">01 / SOURCE</text>
              </svg>
            </div>

            <!-- Step 2: Grid -->
            <div class="flow-panel" data-panel="2">
              <svg viewBox="0 0 520 320" class="tech">
                <text x="40" y="50" font-size="10" letter-spacing="2">02 / GRID</text>
                <!-- pylon 1 -->
                <g class="line">
                  <line x1="100" y1="250" x2="100" y2="110"/>
                  <line x1="80" y1="250" x2="120" y2="250"/>
                  <line x1="80" y1="120" x2="120" y2="120"/>
                  <line x1="70" y1="140" x2="130" y2="140"/>
                  <line x1="85" y1="130" x2="115" y2="130"/>
                </g>
                <!-- pylon 2 -->
                <g class="line">
                  <line x1="260" y1="250" x2="260" y2="110"/>
                  <line x1="240" y1="250" x2="280" y2="250"/>
                  <line x1="240" y1="120" x2="280" y2="120"/>
                  <line x1="230" y1="140" x2="290" y2="140"/>
                  <line x1="245" y1="130" x2="275" y2="130"/>
                </g>
                <!-- pylon 3 -->
                <g class="line">
                  <line x1="420" y1="250" x2="420" y2="110"/>
                  <line x1="400" y1="250" x2="440" y2="250"/>
                  <line x1="400" y1="120" x2="440" y2="120"/>
                  <line x1="390" y1="140" x2="450" y2="140"/>
                  <line x1="405" y1="130" x2="435" y2="130"/>
                </g>
                <!-- wires (signal = active) -->
                <g class="signal" stroke-width="1" fill="none">
                  <path d="M100 140 Q 180 168 260 140"/>
                  <path d="M260 140 Q 340 168 420 140"/>
                  <path d="M100 130 Q 180 158 260 130"/>
                  <path d="M260 130 Q 340 158 420 130"/>
                </g>
                <!-- fibre line -->
                <g class="dashed">
                  <path d="M30 200 L 490 200"/>
                </g>
                <text x="30" y="215" font-size="9" letter-spacing="1.5">CARRIER-NEUTRAL FIBRE · DUAL ENTRY</text>
                <!-- ground -->
                <line x1="0" y1="260" x2="520" y2="260" class="thin"/>
                <text x="40" y="290" font-size="9" letter-spacing="1.5">OLKARIA → SUSWA · 220 KV</text>
              </svg>
            </div>

            <!-- Step 3: Module -->
            <div class="flow-panel" data-panel="3">
              <svg viewBox="0 0 520 320" class="tech">
                <text x="40" y="50" font-size="10" letter-spacing="2">03 / MODULE · 400 KW</text>
                <!-- pod outline (plan view) -->
                <rect class="line" x="60" y="90" width="400" height="190" fill="none"/>
                <!-- IT room 1 -->
                <rect class="hair" x="80" y="110" width="160" height="70" fill="none"/>
                <text x="90" y="125" font-size="9" letter-spacing="1.5">IT ROOM 1 · 200 KW</text>
                <g class="hair">
                  <line x1="90" y1="140" x2="90" y2="170"/>
                  <line x1="105" y1="140" x2="105" y2="170"/>
                  <line x1="120" y1="140" x2="120" y2="170"/>
                  <line x1="135" y1="140" x2="135" y2="170"/>
                  <line x1="150" y1="140" x2="150" y2="170"/>
                  <line x1="165" y1="140" x2="165" y2="170"/>
                  <line x1="180" y1="140" x2="180" y2="170"/>
                  <line x1="195" y1="140" x2="195" y2="170"/>
                  <line x1="210" y1="140" x2="210" y2="170"/>
                  <line x1="225" y1="140" x2="225" y2="170"/>
                </g>
                <!-- IT room 2 -->
                <rect class="hair" x="80" y="190" width="160" height="70" fill="none"/>
                <text x="90" y="205" font-size="9" letter-spacing="1.5">IT ROOM 2 · 200 KW</text>
                <g class="hair">
                  <line x1="90" y1="220" x2="90" y2="250"/>
                  <line x1="105" y1="220" x2="105" y2="250"/>
                  <line x1="120" y1="220" x2="120" y2="250"/>
                  <line x1="135" y1="220" x2="135" y2="250"/>
                  <line x1="150" y1="220" x2="150" y2="250"/>
                  <line x1="165" y1="220" x2="165" y2="250"/>
                  <line x1="180" y1="220" x2="180" y2="250"/>
                  <line x1="195" y1="220" x2="195" y2="250"/>
                  <line x1="210" y1="220" x2="210" y2="250"/>
                  <line x1="225" y1="220" x2="225" y2="250"/>
                </g>
                <!-- power & cooling -->
                <rect x="270" y="110" width="170" height="150" class="signal" opacity="0.08"/>
                <rect x="270" y="110" width="170" height="150" fill="none" stroke="#E7FF00" stroke-width="1"/>
                <text x="280" y="125" font-size="9" class="label-signal" letter-spacing="1.5">POWER &amp; COOLING</text>
                <text x="280" y="148" font-size="9" letter-spacing="1.5">UPS A · 500 KVA</text>
                <text x="280" y="165" font-size="9" letter-spacing="1.5">UPS B · 500 KVA · N+N</text>
                <text x="280" y="192" font-size="9" letter-spacing="1.5">18× BLUEBOX DX</text>
                <text x="280" y="209" font-size="9" letter-spacing="1.5">HOT-AISLE · N+1</text>
                <text x="280" y="240" font-size="9" letter-spacing="1.5">MEET-ME ROOM</text>
                <text x="280" y="257" font-size="9" letter-spacing="1.5">LIQUID · SAFARICOM · SEACOM</text>
                <!-- flow -->
                <g class="thin">
                  <path d="M240 145 L 270 145"/>
                  <path d="M240 225 L 270 225"/>
                </g>
              </svg>
            </div>

            <!-- Step 4: Rack -->
            <div class="flow-panel" data-panel="4">
              <svg viewBox="0 0 520 320" class="tech">
                <text x="40" y="50" font-size="10" letter-spacing="2">04 / RACK · 20 KW</text>
                <!-- rack outline (elevation) -->
                <rect class="line" x="180" y="70" width="160" height="220" fill="none"/>
                <!-- rack units -->
                <g class="hair">
                  <rect x="190" y="78" width="140" height="16" fill="none"/>
                  <rect x="190" y="98" width="140" height="16" fill="none"/>
                  <rect x="190" y="118" width="140" height="22" fill="none"/>
                  <rect x="190" y="142" width="140" height="22" fill="none"/>
                  <rect x="190" y="166" width="140" height="22" fill="none"/>
                </g>
                <!-- gpu highlight -->
                <rect x="190" y="192" width="140" height="30" class="signal" opacity="0.85"/>
                <rect x="190" y="192" width="140" height="30" fill="none" stroke="#E7FF00" stroke-width="1"/>
                <rect x="190" y="224" width="140" height="30" fill="none" stroke="#E2E3DE" stroke-width="0.8"/>
                <!-- pdus bottom -->
                <rect x="190" y="260" width="140" height="20" fill="none" stroke="#6F7287" stroke-width="0.6"/>
                <!-- labels -->
                <text x="350" y="90" font-size="9" letter-spacing="1.5">42U–41U · LEAF SW</text>
                <text x="350" y="112" font-size="9" letter-spacing="1.5">40U–38U · NET</text>
                <text x="350" y="135" font-size="9" letter-spacing="1.5">37U–32U · CPU ×3</text>
                <text x="350" y="185" font-size="9" letter-spacing="1.5">31U–24U · NAS</text>
                <text x="350" y="210" font-size="9" class="label-signal" letter-spacing="1.5">23U–20U · GPU ×8</text>
                <text x="350" y="240" font-size="9" letter-spacing="1.5">19U–16U · GPU ×8</text>
                <text x="350" y="275" font-size="9" letter-spacing="1.5">PDU A / PDU B</text>
                <!-- A/B feeds -->
                <g class="thin">
                  <line x1="180" y1="270" x2="120" y2="270"/>
                  <text x="110" y="273" font-size="9" text-anchor="end">A</text>
                  <line x1="340" y1="270" x2="400" y2="270"/>
                  <text x="410" y="273" font-size="9">B</text>
                </g>
                <text x="170" y="305" font-size="9" letter-spacing="1.5">2× 32 A · A+B REDUNDANT · 20 KW</text>
              </svg>
            </div>

            <!-- Step 5: Workload -->
            <div class="flow-panel" data-panel="5">
              <svg viewBox="0 0 520 320" class="tech">
                <text x="40" y="50" font-size="10" letter-spacing="2">05 / WORKLOAD</text>
                <!-- center node -->
                <circle cx="260" cy="175" r="32" fill="none" stroke="#E7FF00" stroke-width="1.2"/>
                <circle cx="260" cy="175" r="5" class="signal"/>
                <circle cx="260" cy="175" r="8" class="signal pulse" opacity="0.4"/>
                <text x="260" y="230" text-anchor="middle" font-size="10" class="label-signal" letter-spacing="2">SOVEREIGN CLOUD</text>
                <!-- orbiting workloads -->
                <g class="hair">
                  <circle cx="100" cy="110" r="24" fill="none"/>
                  <circle cx="420" cy="110" r="24" fill="none"/>
                  <circle cx="100" cy="250" r="24" fill="none"/>
                  <circle cx="420" cy="250" r="24" fill="none"/>
                </g>
                <text x="100" y="113" text-anchor="middle" font-size="9" letter-spacing="1.5">AI / ML</text>
                <text x="420" y="113" text-anchor="middle" font-size="9" letter-spacing="1.5">HPC</text>
                <text x="100" y="253" text-anchor="middle" font-size="9" letter-spacing="1.5">GENOMICS</text>
                <text x="420" y="253" text-anchor="middle" font-size="9" letter-spacing="1.5">QUANTUM</text>
