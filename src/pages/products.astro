                <rect x="6"   y="22" width="62" height="32" class="signal" opacity="0.18"/>
                <rect x="6"   y="22" width="62" height="32" fill="none" stroke="#E7FF00" stroke-width="0.8"/>
                <text x="14"  y="42" font-size="8" letter-spacing="1" fill="#E7FF00">CITIZEN ID</text>

                <rect x="76"  y="22" width="62" height="32" class="hair" fill="none"/>
                <text x="84"  y="42" font-size="8" letter-spacing="1" fill="#E2E3DE">CBDC</text>

                <rect x="146" y="22" width="62" height="32" class="signal" opacity="0.12"/>
                <rect x="146" y="22" width="62" height="32" fill="none" stroke="#E7FF00" stroke-width="0.6"/>
                <text x="154" y="42" font-size="8" letter-spacing="1" fill="#E7FF00">GOV COPILOT</text>

                <rect x="216" y="22" width="62" height="32" class="hair" fill="none"/>
                <text x="224" y="42" font-size="8" letter-spacing="1" fill="#E2E3DE">FIN AGENT</text>

                <rect x="286" y="22" width="62" height="32" class="hair" fill="none"/>
                <text x="294" y="42" font-size="8" letter-spacing="1" fill="#E2E3DE">HEALTH AI</text>

                <rect x="356" y="22" width="62" height="32" class="signal" opacity="0.18"/>
                <rect x="356" y="22" width="62" height="32" fill="none" stroke="#E7FF00" stroke-width="0.8"/>
