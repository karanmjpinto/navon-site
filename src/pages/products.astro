<script>
  (function () {
    // Valid panel targets (must match data-target on segmented buttons)
    const PRODUCT_PANELS = ['modular', 'turnkey', 'cloud', 'security', 'utility'];

    function activatePanel(target, opts) {
      if (!target || !PRODUCT_PANELS.includes(target)) return false;
      const btn = document.querySelector('.segmented button[data-target="' + target + '"]');
      const panel = document.getElementById(target);
      if (!btn || !panel) return false;
      btn.click();
      if (opts && opts.scroll) {
        // Defer scroll one frame so the panel has rendered after activation
        requestAnimationFrame(function () {
          panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
      return true;
    }

    function handleHash() {
      const hash = (location.hash || '').replace(/^#/, '');
      if (PRODUCT_PANELS.includes(hash)) {
        activatePanel(hash, { scroll: true });
      }
    }

    function init() {
      // 1) Stack-diagram layer click → activate matching panel + scroll
      document.querySelectorAll('.stack-layer[data-jump]').forEach(function (layer) {
        layer.addEventListener('click', function (e) {
          const target = layer.dataset.jump;
          if (activatePanel(target, { scroll: true })) {
            e.preventDefault();
          }
        });
      });

      // 2) Mega-menu / footer / any in-page anchor whose href targets a product panel
      document.querySelectorAll('a[href*="products.html#"], a[href^="#"]').forEach(function (a) {
        const url = new URL(a.getAttribute('href'), location.href);
        const target = (url.hash || '').replace(/^#/, '');
        if (!PRODUCT_PANELS.includes(target)) return;
        // Only intercept if we're on the products page (same path)
        if (url.pathname !== location.pathname) return;
        a.addEventListener('click', function (e) {
          if (activatePanel(target, { scroll: true })) {
            e.preventDefault();
            // Update the URL hash without triggering scroll (smooth scroll already handled)
            if (history.replaceState) history.replaceState(null, '', '#' + target);
          }
        });
      });

