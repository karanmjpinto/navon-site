---
import Site from '../layouts/Site.astro';
import '../styles/products.css';
---
<Site
  title="Products — Navon"
  description="Five product lines: modular DCs, turnkey systems, sovereign cloud, cybersecurity, utility."
  bodyClass="theme-light"
>

<!-- ── HERO ────────────────────────────────────── -->
<section class="page-hero">
  <div class="page-hero-inner" style="grid-template-columns: 1fr;">
    <div>
      <div class="eyebrow"><span class="mark"></span>Products</div>
      <h1 class="page-title reveal">For every workload,<br/><span class="accent">the right Navon.</span></h1>
      <p class="page-lede reveal d1" style="margin-top:24px; max-width: 56ch;">
        One vertically integrated stack — sites, modules, cloud, security,
        applications. Pick the layer that solves your problem; own the rest
        as your demand grows.
      </p>
      <div class="dual-cta reveal d2" style="margin-top:36px;">
        <a href="#stack" class="cta">Browse the stack <span class="arrow">↓</span></a>
        <a href="about.html#contact" class="cta-ghost">Talk to a solutions architect <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>

<!-- ── PRODUCT STACK · FULL-WIDTH DIAGRAM ─────── -->
<section class="stack-section" id="stack">
  <div class="stack-frame">
    <div class="stack-axis" aria-hidden="true">
      <span class="axis-cap top">CLOSER TO USER · APPLICATIONS ↑</span>
      <span class="axis-cap bot">FOUNDATION · PHYSICAL ↓</span>
    </div>

    <div>
      <div class="stack-head reveal">
        <div class="lh-text">
          <div class="eyebrow"><span class="mark"></span>The Navon stack</div>
          <h2>Five layers. One owner. <span class="accent">Yours.</span></h2>
        </div>
        <div class="lh-meta">
          <div><span class="v">5 layers</span> · 1 control plane</div>
          <div>Hover or click any band to dive in</div>
        </div>
      </div>

      <div class="stack-diagram reveal d1">

        <!-- LAYER 05 · APPLICATIONS & AGENTS (top) -->
