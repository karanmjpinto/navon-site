                  <circle cx="14" cy="14" r="5" fill="#E7FF00" fill-opacity="0.85"/>
                  <circle class="pulse" cx="14" cy="14" r="5" fill="#E7FF00" fill-opacity="0.4"/>
                </svg>
              </div>
              <div>
                <div class="ds-mark-name">Pulse node</div>
                <div class="ds-mark-code">.signal.pulse</div>
              </div>
            </div>
            <div class="ds-mark-item">
              <div class="ds-mark-visual">
                <svg viewBox="0 0 48 24" width="48" height="24" class="tech">
