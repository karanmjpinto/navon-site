            <text x="224" y="86" font-size="8" letter-spacing="1.5">.hair</text>
            <text x="224" y="98" font-size="7" letter-spacing="1" fill="#6F7287">0.7px · #9E9F9B · structural</text>

            <!-- .thin — dimension / annotation lines -->
            <line class="thin" x1="30" y1="140" x2="210" y2="140" vector-effect="non-scaling-stroke"/>
            <line class="thin" x1="30" y1="133" x2="30" y2="147" vector-effect="non-scaling-stroke"/>
            <line class="thin" x1="210" y1="133" x2="210" y2="147" vector-effect="non-scaling-stroke"/>
            <text x="120" y="132" text-anchor="middle" font-size="7" letter-spacing="1.5">12.2 M</text>
            <text x="224" y="138" font-size="8" letter-spacing="1.5">.thin</text>
            <text x="224" y="150" font-size="7" letter-spacing="1" fill="#6F7287">0.6px · #6F7287 · dimension</text>

            <!-- .dashed — projected / secondary -->
            <line class="dashed" x1="30" y1="168" x2="210" y2="168" vector-effect="non-scaling-stroke"/>
            <text x="224" y="166" font-size="8" letter-spacing="1.5">.dashed</text>
            <text x="224" y="178" font-size="7" letter-spacing="1" fill="#6F7287">0.8px · 3 4 · projected / secondary</text>

            <!-- Signal usage column -->
            <text x="360" y="10" text-anchor="middle" font-size="8" letter-spacing="2" fill="#6F7287">SIGNAL OPACITY</text>
            <rect x="320" y="18" width="80" height="36" fill="#E7FF00" fill-opacity="0.85" stroke="none"/>
            <text x="360" y="40" text-anchor="middle" font-size="7" letter-spacing="1" fill="#000">0.85 · active</text>
            <rect x="320" y="62" width="80" height="28" fill="#E7FF00" fill-opacity="0.15" stroke="none"/>
            <text x="360" y="80" text-anchor="middle" font-size="7" letter-spacing="1" fill="#9E9F9B">0.15 · hover</text>
            <rect x="320" y="98" width="80" height="28" fill="#E7FF00" fill-opacity="0.06" stroke="none"/>
            <text x="360" y="116" text-anchor="middle" font-size="7" letter-spacing="1" fill="#6F7287">0.06 · bg tint</text>
            <rect x="320" y="134" width="80" height="28" fill="none" stroke="#E7FF00" stroke-width="0.8" vector-effect="non-scaling-stroke"/>
            <text x="360" y="152" text-anchor="middle" font-size="7" letter-spacing="1" fill="#E7FF00">stroke · callout</text>

            <!-- Right annotation arrow -->
            <polyline points="414,36 460,36 480,14" fill="none" stroke="#E7FF00" stroke-width="0.8" vector-effect="non-scaling-stroke"/>
            <circle cx="480" cy="14" r="3" fill="#E7FF00" fill-opacity="0.85"/>
            <text x="482" y="11" font-size="7" letter-spacing="1" fill="#E7FF00">ACTIVE</text>
          </svg>
        </div>
      </div>

      <!-- Live animated specimen -->
      <div class="ds-specimen">
        <div class="ds-specimen-label">Live specimen — .tech .draw · signal appears first, structure draws in · reload to replay</div>
        <div class="ds-specimen-canvas">
          <svg viewBox="0 0 500 250" class="tech draw" xmlns="http://www.w3.org/2000/svg" style="width:100%;">
            <!-- Dimension line — no delay, draws first -->
            <line class="thin" x1="60" y1="18" x2="440" y2="18" vector-effect="non-scaling-stroke"/>
            <line class="thin" x1="60" y1="12" x2="60" y2="24" vector-effect="non-scaling-stroke"/>
            <line class="thin" x1="440" y1="12" x2="440" y2="24" vector-effect="non-scaling-stroke"/>
            <text x="250" y="12" text-anchor="middle" font-size="7" letter-spacing="2">400 KW MODULE · HELL'S GATE SEZ</text>

            <!-- Signal active zone — fills immediately (stroke: none bypasses draw animation) -->
            <rect x="61" y="108" width="198" height="30" fill="#E7FF00" fill-opacity="0.85" stroke="none"/>

            <!-- Outer shell — .line d2 (0.3s delay) -->
            <rect class="line d2" x="60" y="36" width="380" height="162" vector-effect="non-scaling-stroke"/>

            <!-- Central partition — .hair d2 -->
            <line class="hair d2" x1="260" y1="36" x2="260" y2="198" vector-effect="non-scaling-stroke"/>

            <!-- Rack rows — .hair d3 (0.6s delay) -->
            <line class="hair d3" x1="60" y1="78" x2="260" y2="78" vector-effect="non-scaling-stroke"/>
            <line class="hair d3" x1="60" y1="108" x2="260" y2="108" vector-effect="non-scaling-stroke"/>
            <line class="hair d3" x1="60" y1="138" x2="260" y2="138" vector-effect="non-scaling-stroke"/>
            <line class="hair d3" x1="60" y1="168" x2="260" y2="168" vector-effect="non-scaling-stroke"/>
            <line class="hair d3" x1="260" y1="117" x2="440" y2="117" vector-effect="non-scaling-stroke"/>

            <!-- Projected rack boundary — .dashed d3 -->
            <rect class="dashed d3" x="72" y="48" width="176" height="138" vector-effect="non-scaling-stroke"/>

            <!-- Signal callout — d4 (0.9s delay) -->
            <polyline class="signal d4" points="260,123 345,82 438,82" fill="none" stroke-width="0.8" vector-effect="non-scaling-stroke"/>
            <circle class="signal d4" cx="438" cy="82" r="5" fill-opacity="0.85" vector-effect="non-scaling-stroke"/>
            <circle class="pulse" cx="438" cy="82" r="5" fill="#E7FF00" fill-opacity="0.4"/>

            <!-- Labels (text doesn't participate in draw animation) -->
            <text x="160" y="58" text-anchor="middle" font-size="7" letter-spacing="1.5">IT LOAD · 10 RACKS</text>
            <text x="350" y="58" text-anchor="middle" font-size="7" letter-spacing="1.5">PWR + COOLING</text>
            <text x="160" y="126" text-anchor="middle" font-size="7" letter-spacing="1" fill="#000">GPU ACTIVE · INFERENCE</text>
            <text x="345" y="94" font-size="7" letter-spacing="1.5" fill="#E7FF00">NODE ONLINE</text>

            <text x="250" y="230" text-anchor="middle" font-size="7" letter-spacing="2" fill="#3F4157">00°42′S 36°26′E · NAVON COMPUTE · NAIVASHA</text>
          </svg>
        </div>
        <div class="ds-annotation" style="margin-top:12px;">
          <div class="ds-annotation-dot"></div>
          <p>Signal active zone renders first — context before structure. The <code>.d2</code>–<code>.d4</code> stagger (0.3s increments) builds the diagram layer by layer: outer shell → internal structure → annotation callout.</p>
        </div>
      </div>

      <!-- Rules -->
      <div class="ds-diagram-rules">
        <div class="ds-diagram-rule">
          <span class="dr-num">01</span>
          <div>
            <div class="dr-rule">No icon library</div>
            <p class="dr-detail">All marks and diagrams are hand-coded inline SVG. No Lucide, Heroicons, or any external library — this keeps visual weight consistent with the diagram grammar and eliminates a dependency axis.</p>
          </div>
        </div>
        <div class="ds-diagram-rule">
          <span class="dr-num">02</span>
          <div>
            <div class="dr-rule">One signal element per diagram</div>
            <p class="dr-detail">Each diagram highlights exactly one active zone in signal yellow. If multiple elements compete for <code class="ds-code">.signal</code>, the diagram is carrying too many ideas. Split it.</p>
          </div>
        </div>
        <div class="ds-diagram-rule">
          <span class="dr-num">03</span>
          <div>
            <div class="dr-rule">No fills except signal</div>
            <p class="dr-detail">All geometry uses <code class="ds-code">fill="none"</code>. Fills are reserved for <code class="ds-code">.signal</code> highlights and text. No gradients, no pattern fills, no drop shadows.</p>
          </div>
        </div>
        <div class="ds-diagram-rule">
          <span class="dr-num">04</span>
          <div>
            <div class="dr-rule">vector-effect="non-scaling-stroke" on every element</div>
            <p class="dr-detail">The stroke hierarchy (0.6 → 0.7 → 0.8 → 1.2) only holds if strokes don't scale with the SVG. Without this attribute, a thin line on a large viewBox becomes a hairline on mobile. Apply it to every <code class="ds-code">line</code>, <code class="ds-code">rect</code>, <code class="ds-code">path</code>, <code class="ds-code">polyline</code>, and <code class="ds-code">polygon</code>.</p>
          </div>
        </div>
        <div class="ds-diagram-rule">
          <span class="dr-num">05</span>
          <div>
            <div class="dr-rule">Token classes on all SVG text — no inline font-family or fill attributes</div>
            <p class="dr-detail">The <code class="ds-code">.tech text</code> CSS rule sets JetBrains Mono and <code>--mid</code> fill automatically. Use <code class="ds-code">class="label-signal"</code> for signal-yellow text. For map city names use <code class="ds-code">class="city-label"</code> (Space Grotesk, <code>--paper</code>, weight 600) and <code class="ds-code">class="city-phase"</code> (<code>--slate</code>, mono) for sub-labels. <strong style="color:var(--paper);">Never</strong> write <code>font-family="Space Grotesk"</code> or <code>fill="#FFFFFF"</code> directly on SVG elements — that bypasses the token system.</p>
          </div>
        </div>
        <div class="ds-diagram-rule">
          <span class="dr-num">06</span>
          <div>
            <div class="dr-rule">Diagrams are for technical pages only</div>
            <p class="dr-detail">Products, Platform, Quantum Security, Hell's Gate detail. On customer-facing pages (Home, About, Who We Serve, Futures) replace diagrams with photography of Kenyan faces and landscape. The diagram language is a signal of depth — not decoration.</p>
          </div>
        </div>
        <div class="ds-diagram-rule">
          <span class="dr-num">07</span>
          <div>
            <div class="dr-rule">Use CSS .pulse — never SVG &lt;animate&gt; tags</div>
            <p class="dr-detail">SVG <code class="ds-code">&lt;animate&gt;</code> elements do not respect <code>prefers-reduced-motion</code>. The CSS <code class="ds-code">.pulse</code> class uses a keyframe animation guarded by <code>@media (prefers-reduced-motion: reduce)</code>. Always write <code class="ds-code">&lt;circle class="signal pulse" opacity="0.4"/&gt;</code> — never nest <code>&lt;animate&gt;</code> children.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ── 6. BUTTONS ────────────────────────── -->
    <section class="ds-section" id="buttons">
      <div class="ds-section-header">
        <div class="ds-section-num">02 — Components</div>
        <h2 class="ds-section-title">Buttons</h2>
        <p class="ds-section-desc">Two button variants only. Primary is always signal-yellow with black text. Secondary is transparent with a border that turns yellow on hover. Never invert this.</p>
      </div>

      <div class="ds-specimen">
        <div class="ds-specimen-label">Primary — .cta</div>
        <div class="ds-specimen-canvas">
          <div class="ds-row" style="align-items:center;gap:24px;">
            <a href="#" class="cta">See Hell's Gate <span class="arrow">→</span></a>
            <div style="font-family:var(--font-mono);font-size:11px;color:var(--slate);letter-spacing:0.12em;">Default</div>
          </div>
        </div>
        <table class="spec-table" style="margin-top:1px;border:1px solid var(--line);">
          <thead>
            <tr><th>Property</th><th>Value</th></tr>
          </thead>
          <tbody>
