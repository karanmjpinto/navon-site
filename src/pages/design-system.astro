---
// Navon Design System — single source of truth
// Route: /design-system
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Navon · Design System</title>
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/shared.css?v=2" />
  <style>
    /* ── DS chrome ───────────────────────────────── */
    :root {
      --ds-sidebar: 240px;
      --ds-gap: 48px;
    }
    body { background: var(--ink); }

    .ds-layout {
      display: grid;
      grid-template-columns: var(--ds-sidebar) 1fr;
      min-height: 100vh;
    }

    /* sidebar */
    .ds-sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      border-right: 1px solid var(--line);
      padding: 32px 0 40px;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .ds-sidebar::-webkit-scrollbar { width: 0; }
    .ds-brand {
      padding: 0 24px 28px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 20px;
    }
    .ds-brand .wordmark {
      font-family: var(--font-mono);
      font-size: 13px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--paper);
      font-weight: 500;
    }
    .ds-brand .wordmark .dot { color: var(--signal); }
    .ds-brand .ver {
      margin-top: 6px;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      color: var(--slate);
    }
    .ds-nav-group {
      padding: 0 24px 6px;
    }
    .ds-nav-group-label {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--charcoal);
      font-weight: 500;
      padding: 16px 0 8px;
    }
    .ds-nav-group a {
      display: block;
      font-size: 13px;
      color: var(--mid);
      padding: 5px 0;
      letter-spacing: -0.005em;
      transition: color 0.15s ease;
      line-height: 1.5;
    }
    .ds-nav-group a:hover { color: var(--paper); }
    .ds-nav-group a.active { color: var(--signal); }

    /* main — warm off-white editorial surface */
    .ds-main {
      padding: 56px var(--ds-gap) 120px;
      max-width: 1000px;
      background-color: #F7F6F1;
      color: var(--ink);
      /* Rebind dark tokens for light context.
         Specimen canvases and pattern cards re-rebind back to dark inside themselves. */
      --paper: #000000;
      --light: #1a1b28;
      --mid:   #4a4b5e;
      --slate: #555568;
      --line:  rgba(0,0,0,0.10);
      --line-2: rgba(0,0,0,0.16);
    }

    /* section */
    .ds-section {
      padding-top: var(--section-y);
      border-top: 1px solid var(--line);
      margin-top: var(--section-y);
    }
    .ds-section:first-child { border-top: 0; margin-top: 0; padding-top: 0; }
    .ds-section-header {
      margin-bottom: 48px;
    }
    .ds-section-num {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--slate);
      margin-bottom: 10px;
    }
    .ds-section-title {
      font-family: var(--font-display);
      font-size: clamp(28px, 3.2vw, 44px);
      font-weight: 500;
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: 0 0 10px;
    }
    .ds-section-desc {
      font-size: 14.5px;
      color: var(--mid);
      line-height: 1.6;
      max-width: 58ch;
      margin: 0;
    }

    /* specimen blocks */
    .ds-specimen {
      margin-bottom: 40px;
    }
    .ds-specimen-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--slate);
      margin-bottom: 16px;
    }
    .ds-specimen-canvas {
      border: 1px solid var(--line);
      padding: 32px;
      background: rgba(255,255,255,0.012);
      position: relative;
    }
    .ds-specimen-canvas.light {
      background: var(--paper);
      color: var(--ink);
    }
    .ds-code {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      color: var(--slate);
      background: rgba(255,255,255,0.04);
      padding: 2px 7px;
      border-radius: 2px;
    }
    .ds-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: flex-start;
    }
    .ds-col { display: flex; flex-direction: column; gap: 12px; }

    /* colour swatches */
    .swatch-row {
      display: grid;
      grid-template-columns: repeat(9, 1fr);
      gap: 0;
      border: 1px solid var(--line);
      overflow: hidden;
    }
    .swatch {
      aspect-ratio: 1;
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 8px;
    }
    .swatch-name {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      line-height: 1.4;
    }
    .swatch-hex {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.08em;
      opacity: 0.7;
    }
    .swatch-row .swatch:not(:last-child) { border-right: 1px solid rgba(255,255,255,0.06); }

    /* signal row */
    .signal-row {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
      border: 1px solid var(--line);
      overflow: hidden;
    }
    .signal-row .swatch:not(:last-child) { border-right: 1px solid rgba(0,0,0,0.12); }

    /* type scale */
    .type-row {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--line);
    }
    .type-row-item {
      padding: 18px 24px;
      border-bottom: 1px solid var(--line);
      display: grid;
      grid-template-columns: 120px 1fr auto;
      gap: 16px;
      align-items: center;
    }
    .type-row-item:last-child { border-bottom: 0; }
    .type-meta {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      color: var(--slate);
    }
    .type-meta .size { color: var(--mid); font-size: 11px; margin-top: 3px; }
    .type-sample { min-width: 0; }
    .type-class { font-family: var(--font-mono); font-size: 10px; color: var(--charcoal); text-align: right; white-space: nowrap; }

    /* spacing scale */
    .space-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--line);
    }
    .space-row-item {
      padding: 14px 20px;
      border-bottom: 1px solid var(--line);
      display: grid;
      grid-template-columns: 80px 1fr 80px;
      gap: 16px;
      align-items: center;
    }
    .space-row-item:last-child { border-bottom: 0; }
    .space-bar-wrap { display: flex; align-items: center; }
    .space-bar { height: 2px; background: var(--signal); }
    .space-label { font-family: var(--font-mono); font-size: 10px; color: var(--slate); letter-spacing: 0.14em; }
    .space-value { font-family: var(--font-mono); font-size: 10px; color: var(--mid); letter-spacing: 0.1em; text-align: right; }

    /* easing demo */
    .easing-demo {
      display: flex;
      gap: 24px;
      align-items: center;
    }
    .ease-ball {
      width: 16px; height: 16px;
      background: var(--signal);
      border-radius: 1px;
      transition: transform 0.8s cubic-bezier(0.65, 0, 0.35, 1);
    }
    .ease-track {
      flex: 1;
      height: 1px;
      background: var(--line-2);
      position: relative;
    }
    .ease-track:hover .ease-ball { transform: translateX(calc(100% + 16px)); }

    /* button spec table */
    .spec-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    .spec-table th {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--slate);
      padding: 10px 14px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      font-weight: 500;
    }
    .spec-table td {
      padding: 12px 14px;
      border-bottom: 1px solid var(--line);
      color: var(--light);
      vertical-align: top;
    }
    .spec-table tr:last-child td { border-bottom: 0; }
    .spec-table td:first-child { color: var(--mid); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; }

    /* component annotations */
    .ds-annotation {
      display: flex;
      gap: 8px;
      align-items: flex-start;
      margin-top: 12px;
    }
    .ds-annotation-dot {
      width: 6px; height: 6px;
      background: var(--signal);
      flex-shrink: 0;
      margin-top: 6px;
    }
    .ds-annotation p {
      font-size: 12.5px;
      color: var(--mid);
      margin: 0;
      line-height: 1.5;
    }
    .ds-annotation code { font-family: var(--font-mono); font-size: 11px; color: var(--light); }

    /* forbidden words */
    .forbidden-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border: 1px solid var(--line);
    }
    .forbidden-row {
      display: contents;
    }
    .forbidden-row div {
      padding: 12px 18px;
      border-bottom: 1px solid var(--line);
      font-size: 13px;
    }
    .forbidden-row:last-child div { border-bottom: 0; }
    .forbidden-row .bad {
      color: var(--slate);
      text-decoration: line-through;
      text-decoration-color: rgba(255,80,80,0.5);
      border-right: 1px solid var(--line);
    }
    .forbidden-row .good { color: var(--light); }

    /* pattern cards */
    .pattern-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
    }
    .pattern-card {
      background: var(--ink);
      padding: 24px;
    }
    .pattern-card-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--signal);
      margin-bottom: 8px;
    }
    .pattern-card-title {
      font-size: 15px;
      font-weight: 500;
      color: var(--paper);
      margin: 0 0 6px;
    }
    .pattern-card-desc {
      font-size: 13px;
      color: var(--mid);
      line-height: 1.5;
      margin: 0 0 14px;
    }
    .pattern-card-tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .pattern-card-tag {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 3px 8px;
      border: 1px solid var(--line-2);
      color: var(--slate);
    }

    /* responsive */
    @media (max-width: 900px) {
      .ds-layout { grid-template-columns: 1fr; }
      .ds-sidebar { display: none; }
      .ds-main { padding: 40px 20px 80px; }
      .swatch-row { grid-template-columns: repeat(5, 1fr); }
      .forbidden-grid { grid-template-columns: 1fr; }
      .forbidden-row .bad { border-right: 0; border-bottom: 1px solid var(--line); }
      .pattern-grid { grid-template-columns: 1fr; }
      .type-row-item { grid-template-columns: 80px 1fr; }
      .type-class { display: none; }
    }

    /* ── Hallmark redesign · East Africa cultural layer ─
     * Pre-emit critique: P5 H4 E4 S5 R4 V4
     * cultural-layer: Rift Valley · Naivasha · 00°42′S 36°26′E
     */

    /* Topographic texture — dark contour lines at 80px cadence on the light main,
       evoking Rift Valley survey-map intervals. Sidebar stays plain dark. */
    .ds-main {
      background-image: repeating-linear-gradient(
        0deg,
        transparent 0px,
        transparent 79px,
        rgba(0,0,0,0.022) 79px,
        rgba(0,0,0,0.022) 80px
      );
    }

    /* Sidebar scroll progress — 2px signal line on left edge */
    .ds-sidebar { position: relative; overflow: hidden; }
    .ds-progress {
      position: absolute;
      left: 0; top: 0;
      width: 2px;
      background: var(--signal);
      height: 0%;
      transition: height 0.1s linear;
      z-index: 10;
      pointer-events: none;
    }

    /* Sidebar location colophon */
    .ds-location {
      margin-top: auto;
      padding: 20px 24px;
      border-top: 1px solid var(--line);
    }
    .ds-location-name {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--charcoal);
      line-height: 1.6;
    }
    .ds-location-coord {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.14em;
      color: var(--signal);
      margin-top: 3px;
      opacity: 0.85;
    }

    /* Section number — 16px signal dash prefix */
    .ds-section-num {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .ds-section-num::before {
      content: "";
      width: 16px;
      height: 1px;
      background: var(--signal);
      display: inline-block;
      flex-shrink: 0;
      opacity: 0.9;
    }

    /* Overview editorial principle list */
    .ds-overview-principles {
      margin-top: 48px;
      border-top: 1px solid var(--line);
    }
    .ds-principle {
      display: grid;
      grid-template-columns: 40px 1fr;
      gap: 28px;
      padding: 18px 0;
      border-bottom: 1px solid var(--line);
      align-items: baseline;
      transition: background 0.25s ease;
      position: relative;
    }
    .ds-principle::after {
      content: "";
      position: absolute;
      left: 0; bottom: -1px;
      width: 0; height: 1px;
      background: var(--signal);
      transition: width 0.45s var(--easing);
    }
    .ds-principle:hover { background: rgba(231,255,0,0.012); }
    .ds-principle:hover::after { width: 100%; }
    .dp-num {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      color: var(--signal);
      text-transform: uppercase;
      padding-top: 2px;
    }
    .dp-title {
      font-size: 15px;
      font-weight: 500;
      color: var(--paper);
      margin-bottom: 4px;
      letter-spacing: -0.01em;
      font-family: var(--font-display);
    }
    .dp-text {
      font-size: 13.5px;
      color: var(--mid);
      line-height: 1.6;
      margin: 0;
    }
    @media (max-width: 900px) {
      .ds-principle { grid-template-columns: 1fr; gap: 6px; }
    }

    /* Palette field note — Rift Valley provenance annotation */
    .ds-field-note {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--charcoal);
      letter-spacing: 0.06em;
      line-height: 1.75;
      margin-top: 16px;
      padding: 12px 14px;
      border-left: 2px solid var(--signal);
      max-width: 72ch;
      background: rgba(231,255,0,0.03);
    }

    /* Easing demo — ball inside track, moves on hover */
    .easing-demo { display: flex; align-items: center; }
    .ease-track {
      flex: 1;
      height: 2px;
      background: var(--line-2);
      position: relative;
      overflow: visible;
      cursor: default;
    }
    .ease-ball {
      width: 16px; height: 16px;
      background: var(--signal);
      border-radius: 1px;
      position: absolute;
      top: 50%;
      left: 0;
      transform: translateY(-50%);
      transition: left 0.8s cubic-bezier(0.65, 0, 0.35, 1);
    }
    .ease-track:hover .ease-ball { left: calc(100% - 16px); }

    /* Forbidden words — header row */
    .forbidden-row.forbidden-header .bad {
      background: var(--signal);
      color: var(--ink);
      font-family: var(--font-mono);
      font-size: 9.5px;
      font-weight: 600;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      text-decoration: none;
    }
    .forbidden-row.forbidden-header .good {
      background: rgba(255,255,255,0.04);
      color: var(--slate);
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 500;
    }

    /* Voice narratives — editorial list (replaces numbered cols-2) */
    .ds-narrative-list {
      border-top: 1px solid var(--line);
      margin-top: 0;
    }
    .ds-narrative-item {
      display: grid;
      grid-template-columns: 40px 1fr;
      gap: 32px;
      padding: 24px 0;
      border-bottom: 1px solid var(--line);
      position: relative;
      transition: background 0.25s ease;
    }
    .ds-narrative-item::before {
      content: "";
      position: absolute;
      top: 0; left: 0;
      width: 0; height: 2px;
      background: var(--signal);
      transition: width 0.45s var(--easing);
    }
    .ds-narrative-item:hover { background: rgba(231,255,0,0.012); }
    .ds-narrative-item:hover::before { width: 100%; }
    .dn-num {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      color: var(--signal);
      padding-top: 4px;
      text-transform: uppercase;
    }
    .dn-body {}
    .dn-body h4 {
      font-family: var(--font-display);
      font-size: 16px;
      font-weight: 500;
      letter-spacing: -0.012em;
      margin: 0 0 6px;
      color: var(--paper);
      font-style: italic;
    }
    .dn-body p {
      font-size: 13.5px;
      color: var(--mid);
      margin: 0;
      line-height: 1.55;
    }
    @media (max-width: 900px) {
      .ds-narrative-item { grid-template-columns: 1fr; gap: 8px; }
    }

    /* ── Icons & Diagrams ───────────────────────────── */

    /* Mark vocabulary — shown inside dark specimen canvas */
    .ds-marks-row {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
    }
    .ds-mark-item {
      padding: 22px 12px 16px;
      border-right: 1px solid rgba(255,255,255,0.08);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      text-align: center;
    }
    .ds-mark-item:last-child { border-right: 0; }
    .ds-mark-visual {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 28px;
    }
    .ds-mark-name {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #9E9F9B;
      line-height: 1.6;
    }
    .ds-mark-code {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.12em;
      color: #6F7287;
      margin-top: 2px;
    }
    @media (max-width: 900px) {
      .ds-marks-row { grid-template-columns: repeat(3, 1fr); }
      .ds-mark-item:nth-child(3) { border-right: 0; }
      .ds-mark-item:nth-child(4),
      .ds-mark-item:nth-child(5) { border-top: 1px solid rgba(255,255,255,0.08); }
      .ds-mark-item:nth-child(4) { border-right: 1px solid rgba(255,255,255,0.08); }
    }

    /* Diagram rules list — on light main */
    .ds-diagram-rules {
      border-top: 1px solid var(--line);
      margin-top: 36px;
    }
    .ds-diagram-rule {
      display: grid;
      grid-template-columns: 32px 1fr;
      gap: 20px;
      padding: 16px 0;
      border-bottom: 1px solid var(--line);
      align-items: baseline;
    }
    .ds-diagram-rule:last-child { border-bottom: 0; }
    .dr-num {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.2em;
      color: var(--charcoal);
      text-transform: uppercase;
    }
    .dr-rule {
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 500;
      color: var(--paper);
      margin: 0 0 3px;
    }
    .dr-detail {
      font-size: 12.5px;
      color: var(--mid);
      margin: 0;
      line-height: 1.5;
    }

    /* ── Light-main scoped overrides ────────────────
     * Dark specimen frames re-rebind tokens to their original dark values.
     * Signal yellow marks are swapped to charcoal (invisible on #F7F6F1).
     */

    /* Dark preview frames stay dark — specimens show real dark-mode output */
    .ds-main .ds-specimen-canvas {
      background: #09090d;
      color: #E2E3DE;
      border-color: rgba(255,255,255,0.08);
      --paper: #ffffff;
      --light: #E2E3DE;
      --mid:   #9E9F9B;
      --slate: #6F7287;
      --line:  rgba(255,255,255,0.08);
      --line-2: rgba(255,255,255,0.14);
    }
    .ds-main .ds-specimen-canvas .ds-code {
      background: rgba(255,255,255,0.07);
      color: #9E9F9B;
    }

    /* Pattern cards are page-structure specimens — keep dark */
    .ds-main .pattern-card {
      background: #07080A;
      --paper: #ffffff;
      --light: #E2E3DE;
      --mid:   #9E9F9B;
      --line:  rgba(255,255,255,0.08);
    }

    /* ds-code on light surface */
    .ds-main .ds-code {
      background: rgba(0,0,0,0.07);
      color: var(--charcoal);
    }

    /* Swatch grid borders */
    .ds-main .swatch-row { border-color: rgba(0,0,0,0.10); }
    .ds-main .swatch-row .swatch:not(:last-child) { border-right-color: rgba(0,0,0,0.07); }

    /* numbered-item signal mark */
    .ds-main .numbered-item .num { color: var(--charcoal); }

    /* Signal → charcoal for marks that would be invisible on off-white */
    .ds-main .ds-section-num::before { background: var(--charcoal); opacity: 1; }
    .ds-main .dp-num { color: var(--charcoal); }
    .ds-main .dn-num { color: var(--charcoal); }
    .ds-main .ds-annotation-dot { background: var(--charcoal); }
    .ds-main .ds-field-note {
      border-left-color: var(--charcoal);
      background: rgba(0,0,0,0.04);
      color: var(--charcoal);
    }
    .ds-main .ds-principle::after { background: var(--charcoal); }
    .ds-main .ds-narrative-item::before { background: var(--charcoal); }
    .ds-main .dc-coord { color: var(--charcoal); }
    .ds-main .dc-mark { background: var(--charcoal); }
    .ds-main .space-bar { background: var(--charcoal); }
    .ds-main .ds-progress { background: var(--charcoal); }

    /* h1 accent — yellow highlight-bar replaces pure signal text colour */
    .ds-hero-accent {
      font-style: italic;
      font-weight: 400;
      background: linear-gradient(180deg, transparent 54%, rgba(231,255,0,0.58) 54%);
      color: var(--ink);
      padding: 0 3px;
    }

    /* ── Cultural Roots block ────────────────────── */
    .ds-roots {
      margin-top: 48px;
      padding-top: 28px;
      border-top: 1px solid var(--line);
    }
    .ds-roots-header {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--charcoal);
      margin-bottom: 20px;
    }
    .ds-roots-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
      border: 1px solid var(--line);
    }
    .ds-root-item {
      padding: 18px 20px;
      border-bottom: 1px solid var(--line);
    }
    .ds-root-item:nth-child(odd) { border-right: 1px solid var(--line); }
    .ds-root-item:nth-last-child(-n+2) { border-bottom: 0; }
    .ds-root-item:last-child:nth-child(odd) { border-bottom: 0; }
    .ri-label {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--charcoal);
      margin-bottom: 6px;
    }
    .ri-value {
      font-family: var(--font-display);
      font-size: 15px;
      font-weight: 500;
      letter-spacing: -0.01em;
      color: var(--paper);
      margin: 0 0 4px;
    }
    .ri-note {
      font-size: 12.5px;
      color: var(--mid);
      margin: 0;
      line-height: 1.5;
    }
    @media (max-width: 900px) {
      .ds-roots-grid { grid-template-columns: 1fr; }
      .ds-root-item:nth-child(odd) { border-right: 0; }
      .ds-root-item:nth-last-child(-n+2) { border-bottom: 1px solid var(--line); }
      .ds-root-item:last-child { border-bottom: 0; }
    }

    /* ── Swahili display specimen ────────────────── */
    .ds-swahili {
      margin-top: 40px;
      padding: 28px 24px;
      border: 1px solid var(--line);
    }
    .ds-swahili-main {
      font-family: var(--font-display);
      font-size: clamp(48px, 6vw, 80px);
      font-weight: 500;
      letter-spacing: -0.04em;
      line-height: 0.95;
      color: var(--paper);
      margin: 0 0 6px;
    }
    .ds-swahili-gloss {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--charcoal);
      margin: 0 0 14px;
    }
    .ds-swahili-note {
      font-size: 12.5px;
      color: var(--mid);
      max-width: 52ch;
      line-height: 1.55;
      margin: 0;
    }

    /* ── Geographic specificity grid ─────────────── */
    .ds-geo-label {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--charcoal);
      margin: 36px 0 16px;
    }
    .ds-geo-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      border: 1px solid var(--line);
    }
    .ds-geo-item {
      padding: 18px 16px;
      border-right: 1px solid var(--line);
    }
    .ds-geo-item:last-child { border-right: 0; }
    .dg-scope {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--charcoal);
      margin-bottom: 8px;
    }
    .dg-term {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 500;
      letter-spacing: -0.02em;
      color: var(--paper);
      margin: 0 0 6px;
    }
    .dg-when {
      font-size: 12px;
      color: var(--mid);
      line-height: 1.5;
      margin: 0;
    }
    @media (max-width: 900px) {
      .ds-geo-grid { grid-template-columns: 1fr 1fr; }
      .ds-geo-item:nth-child(even) { border-right: 0; }
      .ds-geo-item { border-bottom: 1px solid var(--line); }
      .ds-geo-item:nth-last-child(-n+2) { border-bottom: 0; }
    }

    /* Colophon — token section footer */
    .ds-colophon {
      margin-top: 64px;
      padding-top: 32px;
      border-top: 1px solid var(--line);
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      flex-wrap: wrap;
      gap: 16px;
    }
    .dc-left { display: flex; align-items: center; gap: 14px; }
    .dc-mark { width: 8px; height: 8px; background: var(--signal); flex-shrink: 0; }
    .dc-title {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--paper);
      font-weight: 500;
    }
    .dc-meta {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--charcoal);
      margin-top: 4px;
    }
    .dc-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
    .dc-coord {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.2em;
      color: var(--signal);
      text-transform: uppercase;
    }
    .dc-back {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--slate);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      transition: color 0.2s ease;
    }
    .dc-back:hover { color: var(--signal); }
  </style>
</head>
<body>

<div class="ds-layout">

  <!-- ── Sidebar ──────────────────────────────── -->
  <aside class="ds-sidebar">
    <div class="ds-progress" id="ds-progress"></div>
    <div class="ds-brand">
      <div class="wordmark">NAVON<span class="dot">.</span></div>
      <div class="ver">Design System · v1.1 · #E7FF00</div>
    </div>

    <div class="ds-nav-group">
      <div class="ds-nav-group-label">Foundations</div>
      <a href="#colour">Colour</a>
      <a href="#typography">Typography</a>
      <a href="#spacing">Spacing &amp; Layout</a>
      <a href="#motion">Motion</a>
      <a href="#diagrams">Icons &amp; Diagrams</a>
    </div>

    <div class="ds-nav-group">
      <div class="ds-nav-group-label">Components</div>
      <a href="#buttons">Buttons</a>
      <a href="#labels">Labels &amp; Tags</a>
      <a href="#cards">Cards</a>
      <a href="#navigation">Navigation</a>
      <a href="#segmented">Segmented Control</a>
    </div>

    <div class="ds-nav-group">
      <div class="ds-nav-group-label">Patterns</div>
      <a href="#page-patterns">Page Patterns</a>
      <a href="#dark-light">Dark / Light Split</a>
      <a href="#voice">Voice &amp; Language</a>
    </div>

    <div class="ds-nav-group">
      <div class="ds-nav-group-label">Reference</div>
      <a href="#tokens">Token Reference</a>
    </div>

    <div class="ds-location">
      <div class="ds-location-name">Navon · Kenya</div>
      <div class="ds-location-coord">00°42′S 36°26′E</div>
    </div>
  </aside>

  <!-- ── Main ─────────────────────────────────── -->
  <main class="ds-main">

    <!-- Overview -->
    <div class="ds-section" id="overview">
      <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
        <span style="width:8px;height:8px;background:var(--signal);display:inline-block;"></span>
        <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:var(--mid);">Navon · Design System</span>
      </div>
      <h1 style="font-size:clamp(40px,5vw,72px);font-weight:500;letter-spacing:-0.04em;line-height:0.96;margin:0 0 20px;">Build Africa's<br/><span class="ds-hero-accent">AI future</span><br/>consistently.</h1>
      <p style="font-size:16px;color:var(--mid);line-height:1.65;max-width:54ch;margin:0 0 40px;">A single source of truth for every visual decision on the Navon website and products. Tokens first, components second, patterns third.</p>

      <div class="ds-overview-principles">
        <div class="ds-principle">
          <span class="dp-num">01</span>
          <div>
            <div class="dp-title">Token-first</div>
            <p class="dp-text">All colour, type, and spacing decisions start from a named CSS variable — never a hardcoded hex.</p>
          </div>
        </div>
        <div class="ds-principle">
          <span class="dp-num">02</span>
          <div>
            <div class="dp-title">Africa-forward</div>
            <p class="dp-text">Visuals and language must speak to African business leaders first. Technical diagrams earn their place.</p>
          </div>
        </div>
        <div class="ds-principle">
          <span class="dp-num">03</span>
          <div>
            <div class="dp-title">One idea per section</div>
            <p class="dp-text">White space is structure. No section carries more than one idea. Hierarchy replaces density.</p>
          </div>
        </div>
      </div>

      <!-- Cultural Anchor — geography behind the brand -->
      <div class="ds-roots">
        <div class="ds-roots-header">Cultural anchor — the geography behind the brand</div>
        <div class="ds-roots-grid">
          <div class="ds-root-item">
            <div class="ri-label">Site</div>
            <div class="ri-value">Hell's Gate SEZ · Naivasha</div>
            <p class="ri-note">The physical location of Navon's data centre — geothermal steam, not diesel. Every design decision should trace to a real place.</p>
          </div>
          <div class="ds-root-item">
            <div class="ri-label">Region</div>
            <div class="ri-value">Rift Valley, Kenya</div>
            <p class="ri-note">East Africa's technology corridor. Photography and illustration should foreground this landscape — escarpment, acacia, red laterite road.</p>
          </div>
          <div class="ds-root-item">
            <div class="ri-label">Context</div>
            <div class="ri-value">Silicon Savannah</div>
            <p class="ri-note">Nairobi's tech ecosystem — the buyers, the talent, the ambition. Navon is local infrastructure for a local market, not a Western import.</p>
          </div>
          <div class="ds-root-item">
            <div class="ri-label">Photography rule</div>
            <div class="ri-value">Faces first</div>
            <p class="ri-note">Customer-facing pages lead with Kenyan and East African faces and landscape. Diagrams earn their place on technical pages only.</p>
          </div>
        </div>
      </div>
    </div>


    <!-- ── 1. COLOUR ──────────────────────────── -->
    <section class="ds-section" id="colour">
      <div class="ds-section-header">
        <div class="ds-section-num">01 — Foundations</div>
        <h2 class="ds-section-title">Colour</h2>
        <p class="ds-section-desc">Two families: a nine-step neutral ramp from <code class="ds-code">--ink</code> to <code class="ds-code">--paper</code>, and a single brand accent <code class="ds-code">--signal</code>. Signal is never used as body text — only buttons, accents, and graphic highlights.</p>
      </div>

      <!-- Neutral ramp -->
      <div class="ds-specimen">
        <div class="ds-specimen-label">Neutral scale — ink → paper</div>
        <div class="swatch-row">
          <div class="swatch" style="background:#0b0b07;">
            <span class="swatch-name" style="color:rgba(255,255,255,0.4);">ink</span>
            <span class="swatch-hex" style="color:rgba(255,255,255,0.3);">#0b0b07</span>
          </div>
          <div class="swatch" style="background:#07080A;">
            <span class="swatch-name" style="color:rgba(255,255,255,0.4);">ink-2</span>
            <span class="swatch-hex" style="color:rgba(255,255,255,0.3);">#07080A</span>
          </div>
          <div class="swatch" style="background:#3F4157;">
            <span class="swatch-name" style="color:rgba(255,255,255,0.6);">charcoal</span>
            <span class="swatch-hex" style="color:rgba(255,255,255,0.4);">#3F4157</span>
          </div>
          <div class="swatch" style="background:#6F7287;">
            <span class="swatch-name" style="color:rgba(255,255,255,0.7);">slate</span>
            <span class="swatch-hex" style="color:rgba(255,255,255,0.5);">#6F7287</span>
          </div>
          <div class="swatch" style="background:#9E9F9B;">
            <span class="swatch-name" style="color:rgba(255,255,255,0.8);">mid</span>
            <span class="swatch-hex" style="color:rgba(255,255,255,0.6);">#9E9F9B</span>
          </div>
          <div class="swatch" style="background:#E2E3DE;">
            <span class="swatch-name" style="color:rgba(0,0,0,0.5);">light</span>
            <span class="swatch-hex" style="color:rgba(0,0,0,0.35);">#E2E3DE</span>
          </div>
          <div class="swatch" style="background:#F3F4F4;">
            <span class="swatch-name" style="color:rgba(0,0,0,0.45);">vlight</span>
            <span class="swatch-hex" style="color:rgba(0,0,0,0.3);">#F3F4F4</span>
          </div>
          <div class="swatch" style="background:#FFFFFF;border-left:1px solid var(--line);">
            <span class="swatch-name" style="color:rgba(0,0,0,0.45);">paper</span>
            <span class="swatch-hex" style="color:rgba(0,0,0,0.3);">#FFFFFF</span>
          </div>
          <div class="swatch" style="background:#E7FF00;">
            <span class="swatch-name" style="color:rgba(0,0,0,0.55);">signal</span>
            <span class="swatch-hex" style="color:rgba(0,0,0,0.4);">#E7FF00</span>
          </div>
        </div>
        <p class="ds-field-note">The neutral ramp traces Rift Valley light: deep basalt of Mount Longonot at dusk → bleached silt of Lake Naivasha at noon. Signal is East African sunrise — deployed only where attention is earned.</p>
      </div>

      <!-- Signal scale -->
      <div class="ds-specimen">
        <div class="ds-specimen-label">Signal — usage rules</div>
        <div class="signal-row">
          <div class="swatch" style="background:#E7FF00;aspect-ratio:auto;padding:20px 16px 16px;">
            <span class="swatch-name" style="color:rgba(0,0,0,0.6);font-size:10px;">Button fill</span>
          </div>
          <div class="swatch" style="background:rgba(231,255,0,0.1);aspect-ratio:auto;padding:20px 16px 16px;border-left:1px solid var(--line);">
            <span class="swatch-name" style="color:var(--mid);font-size:10px;">Card hover</span>
          </div>
          <div class="swatch" style="background:rgba(231,255,0,0.06);aspect-ratio:auto;padding:20px 16px 16px;border-left:1px solid var(--line);">
            <span class="swatch-name" style="color:var(--mid);font-size:10px;">Subtle bg</span>
          </div>
          <div class="swatch" style="background:rgba(231,255,0,0.6);aspect-ratio:auto;padding:20px 16px 16px;border-left:1px solid var(--line);">
            <span class="swatch-name" style="color:rgba(0,0,0,0.5);font-size:10px;">Glow shadow</span>
          </div>
          <div class="swatch" style="background:var(--ink);aspect-ratio:auto;padding:20px 16px 16px;border-left:1px solid var(--line);">
            <div style="width:8px;height:8px;background:var(--signal);margin-bottom:8px;"></div>
            <span class="swatch-name" style="color:var(--mid);font-size:10px;">Dot / mark</span>
          </div>
        </div>
        <div class="ds-annotation">
          <div class="ds-annotation-dot"></div>
          <p><strong style="color:var(--paper);">Signal is never used as text colour.</strong> Use it for buttons, decorative dots, top-border accents, hover glows, and the selection highlight. Body copy stays <code>--paper</code>, <code>--light</code>, or <code>--mid</code>.</p>
        </div>
      </div>

      <!-- Alpha overlays -->
      <div class="ds-specimen">
        <div class="ds-specimen-label">Structural overlays</div>
        <div class="numbered cols-2" style="margin-top:0;">
          <div class="numbered-item" style="min-height:80px;padding:18px 20px;">
            <span class="num">--line</span>
            <p>rgba(255,255,255,0.08) — default borders, dividers</p>
          </div>
          <div class="numbered-item" style="min-height:80px;padding:18px 20px;">
            <span class="num">--line-2</span>
            <p>rgba(255,255,255,0.14) — scrolled nav, active card borders</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ── 2. TYPOGRAPHY ──────────────────────── -->
    <section class="ds-section" id="typography">
      <div class="ds-section-header">
        <div class="ds-section-num">01 — Foundations</div>
        <h2 class="ds-section-title">Typography</h2>
        <p class="ds-section-desc">Two typefaces only. <strong style="color:var(--paper);">Space Grotesk</strong> for all editorial and display text. <strong style="color:var(--paper);">JetBrains Mono</strong> for labels, metadata, code, and eyebrows — never for body paragraphs.</p>
      </div>

      <!-- Type scale -->
      <div class="ds-specimen">
        <div class="ds-specimen-label">Display scale — Space Grotesk</div>
        <div class="type-row">
          <div class="type-row-item">
            <div class="type-meta">Hero<div class="size">clamp(56px, 9vw, 128px)</div></div>
            <div class="type-sample" style="font-size:clamp(40px,5vw,64px);font-weight:500;letter-spacing:-0.04em;line-height:0.96;">Navon</div>
            <div class="type-class">.hero-headline</div>
          </div>
          <div class="type-row-item">
            <div class="type-meta">Page title<div class="size">clamp(48px, 8vw, 120px)</div></div>
            <div class="type-sample" style="font-size:clamp(36px,4.5vw,56px);font-weight:500;letter-spacing:-0.04em;line-height:0.96;">Africa</div>
            <div class="type-class">.page-title</div>
          </div>
          <div class="type-row-item">
            <div class="type-meta">Section title<div class="size">clamp(36px, 4.6vw, 64px)</div></div>
            <div class="type-sample" style="font-size:clamp(28px,3.5vw,44px);font-weight:500;letter-spacing:-0.03em;line-height:1.02;">Four layers.</div>
            <div class="type-class">.section-title</div>
          </div>
          <div class="type-row-item">
            <div class="type-meta">Card heading<div class="size">18–24px</div></div>
            <div class="type-sample" style="font-size:20px;font-weight:500;letter-spacing:-0.012em;">Sovereign cloud</div>
            <div class="type-class">h3 / h4</div>
          </div>
          <div class="type-row-item">
            <div class="type-meta">Body<div class="size">16–17px</div></div>
            <div class="type-sample" style="font-size:16px;color:var(--light);line-height:1.6;max-width:48ch;">Navon provides AI compute, sovereign cloud, and quantum-safe security to enterprises across Africa.</div>
            <div class="type-class">.page-lede / p</div>
          </div>
          <div class="type-row-item">
            <div class="type-meta">Small body<div class="size">13–14px</div></div>
            <div class="type-sample" style="font-size:13.5px;color:var(--mid);line-height:1.55;">Supporting detail text — card descriptions, footnotes, helper copy.</div>
            <div class="type-class">.desc / small</div>
          </div>
        </div>
      </div>

      <div class="ds-specimen">
        <div class="ds-specimen-label">Mono scale — JetBrains Mono</div>
        <div class="type-row">
          <div class="type-row-item">
            <div class="type-meta">Eyebrow<div class="size">11px / 0.24em</div></div>
            <div class="type-sample">
              <span class="eyebrow"><span class="mark"></span>Infrastructure</span>
            </div>
            <div class="type-class">.eyebrow</div>
          </div>
          <div class="type-row-item">
            <div class="type-meta">Label / nav<div class="size">11px / 0.22em</div></div>
            <div class="type-sample" style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:var(--mid);">NAVON · 2026</div>
            <div class="type-class">.mono</div>
          </div>
          <div class="type-row-item">
            <div class="type-meta">Wordmark<div class="size">13–14px / 0.22em</div></div>
            <div class="type-sample" style="font-family:var(--font-mono);font-size:14px;letter-spacing:0.22em;text-transform:uppercase;font-weight:500;">NAVON<span style="color:var(--signal);">.</span></div>
            <div class="type-class">.wordmark</div>
          </div>
          <div class="type-row-item">
            <div class="type-meta">Spec / data<div class="size">10–11px</div></div>
            <div class="type-sample" style="font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--slate);">PUE <span style="color:var(--paper);">1.29</span></div>
            <div class="type-class">.spec-card-num</div>
          </div>
        </div>
      </div>

      <!-- Accent -->
      <div class="ds-specimen">
        <div class="ds-specimen-label">Accent — italic + signal</div>
        <div class="ds-specimen-canvas">
          <div style="font-size:clamp(28px,4vw,52px);font-weight:500;letter-spacing:-0.03em;line-height:1.05;">
            Four layers.<br/><span style="color:var(--signal);font-style:italic;font-weight:400;">One sovereign stack.</span>
          </div>
          <div class="ds-annotation" style="margin-top:16px;">
            <div class="ds-annotation-dot"></div>
            <p>Italic + signal weight 400 is used for the highlighted line in section titles. <code>.accent</code> class on a <code>&lt;span&gt;</code> inside <code>.section-title</code> or <code>.page-title</code>.</p>
          </div>
        </div>
      </div>

      <!-- Swahili specimen — pan-African readability anchor -->
      <div class="ds-swahili">
        <div class="ds-specimen-label" style="margin-bottom:20px;">Language specimen — Kiswahili</div>
        <div class="ds-swahili-main">Kujenga.</div>
        <div class="ds-swahili-gloss">to build · Kiswahili</div>
        <p class="ds-swahili-note">Space Grotesk carries Swahili copy without modification — clean Latin-Supplement coverage supports the full Kenyan and East African character set. All Navon display headlines work bilingually. Secondary test words: <em style="font-style:italic;color:var(--charcoal);">Ujenzi · Mazingira · Baadaye</em> (construction · environment · future).</p>
      </div>
    </section>


    <!-- ── 3. SPACING ────────────────────────── -->
    <section class="ds-section" id="spacing">
      <div class="ds-section-header">
        <div class="ds-section-num">01 — Foundations</div>
        <h2 class="ds-section-title">Spacing &amp; Layout</h2>
        <p class="ds-section-desc">All spacing is token-driven. The two most important are <code class="ds-code">--px</code> (horizontal page padding) and <code class="ds-code">--section-y</code> (vertical section rhythm) — both are fluid clamps.</p>
      </div>

      <div class="ds-specimen">
        <div class="ds-specimen-label">Core layout tokens</div>
        <div class="space-grid">
          <div class="space-row-item">
            <span class="space-label">--nav-h</span>
            <div class="space-bar-wrap"><div class="space-bar" style="width:68px;"></div></div>
            <span class="space-value">68px</span>
          </div>
          <div class="space-row-item">
            <span class="space-label">--px</span>
            <div class="space-bar-wrap"><div class="space-bar" style="width:min(56px,8vw);"></div></div>
            <span class="space-value">clamp(20px, 4vw, 56px)</span>
          </div>
          <div class="space-row-item">
            <span class="space-label">--section-y</span>
            <div class="space-bar-wrap"><div class="space-bar" style="width:min(120px,12vw);"></div></div>
            <span class="space-value">clamp(96px, 12vw, 160px)</span>
          </div>
          <div class="space-row-item">
            <span class="space-label">Max width</span>
            <div class="space-bar-wrap"><div class="space-bar" style="width:100%;"></div></div>
            <span class="space-value">1280px</span>
          </div>
        </div>
      </div>

      <div class="ds-specimen">
        <div class="ds-specimen-label">Grid system</div>
        <div class="numbered cols-3" style="margin-top:0;">
          <div class="numbered-item" style="min-height:100px;">
            <span class="num">1-col</span>
            <h4>Full-width</h4>
            <p>Hero sections, photography, maps. No max-width constraint below 1280px.</p>
          </div>
          <div class="numbered-item" style="min-height:100px;">
            <span class="num">2-col</span>
            <h4>Section header</h4>
            <p>Title left, lede/meta right. Collapses to 1-col at 820px. Used in .section-head.</p>
          </div>
          <div class="numbered-item" style="min-height:100px;">
            <span class="num">3–5-col</span>
            <h4>Feature grids</h4>
            <p>.numbered.cols-3 / cols-5. Collapses to 2-col at 1100px, 1-col at 640px.</p>
          </div>
        </div>
      </div>

      <div class="ds-specimen">
        <div class="ds-specimen-label">Border radius</div>
        <div class="ds-row" style="gap:24px;align-items:center;">
          <div>
            <div style="width:48px;height:48px;background:var(--signal);border-radius:2px;"></div>
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--slate);margin-top:8px;letter-spacing:0.12em;">2px — buttons, cards, inputs</div>
          </div>
          <div>
            <div style="width:48px;height:48px;background:var(--signal);border-radius:999px;"></div>
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--slate);margin-top:8px;letter-spacing:0.12em;">999px — tags, pills, badges</div>
          </div>
          <div>
            <div style="width:48px;height:48px;background:var(--signal);border-radius:0px;"></div>
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--slate);margin-top:8px;letter-spacing:0.12em;">0 — SVG shapes, lines, dividers</div>
          </div>
        </div>
      </div>
    </section>


    <!-- ── 4. MOTION ──────────────────────────── -->
    <section class="ds-section" id="motion">
      <div class="ds-section-header">
        <div class="ds-section-num">01 — Foundations</div>
        <h2 class="ds-section-title">Motion</h2>
        <p class="ds-section-desc">All transitions use a single shared easing curve. Motion is purposeful and restrained — it guides attention, not decorates.</p>
      </div>

      <div class="ds-specimen">
        <div class="ds-specimen-label">Easing curve — --easing · hover to play</div>
        <div class="ds-specimen-canvas">
          <div style="font-family:var(--font-mono);font-size:12px;color:var(--signal);margin-bottom:20px;letter-spacing:0.12em;">cubic-bezier(0.65, 0, 0.35, 1)</div>
          <p style="font-size:13.5px;color:var(--mid);margin:0 0 20px;">Smooth deceleration — fast in, eases out. Used for nav, buttons, dropdowns, hero reveals, and card transitions.</p>
          <div class="easing-demo">
            <div class="ease-track">
              <div class="ease-ball"></div>
            </div>
          </div>
          <div class="ds-annotation" style="margin-top:20px;">
            <div class="ds-annotation-dot"></div>
            <p>Standard durations: <code>0.2s</code> for hover states, <code>0.4–0.5s</code> for structural transitions (nav slide, card reveals), <code>0.8s</code> for scroll-reveal animations.</p>
          </div>
        </div>
      </div>

      <div class="ds-specimen">
        <div class="ds-specimen-label">Scroll reveal — .reveal</div>
        <div class="ds-specimen-canvas">
          <p style="font-size:13.5px;color:var(--mid);margin:0 0 16px;">Elements enter with <code class="ds-code">opacity: 0 → 1</code> and <code class="ds-code">translateY(16px → 0)</code>. Stagger delays available via <code class="ds-code">.d1</code>–<code class="ds-code">.d6</code> (0.08s increments). Triggered by IntersectionObserver in shared.js.</p>
          <div class="ds-row">
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--slate);letter-spacing:0.14em;">.reveal — no delay</div>
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--slate);letter-spacing:0.14em;">.reveal.d1 — 80ms</div>
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--slate);letter-spacing:0.14em;">.reveal.d2 — 160ms</div>
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--slate);letter-spacing:0.14em;">.reveal.d3 — 240ms</div>
          </div>
          <div class="ds-annotation" style="margin-top:16px;">
            <div class="ds-annotation-dot"></div>
            <p><strong style="color:var(--paper);">Scope rule:</strong> <code>.reveal</code> is for section-level elements only — <code>.section-title</code>, <code>.section-lede</code>, and the delivery banner. Never on individual child items (<code>.pillar</code>, <code>.delivery-card</code>, <code>.phase</code>). Animate-on-scroll on every child card is an AI-slop tell.</p>
          </div>
        </div>
      </div>

      <div class="ds-specimen">
        <div class="ds-specimen-label">SVG draw animation — .draw</div>
        <div class="ds-specimen-canvas">
          <p style="font-size:13.5px;color:var(--mid);margin:0;">SVG paths on technical illustrations animate from <code class="ds-code">stroke-dashoffset: 1200 → 0</code> over 2.2s. Used for the fin.ai-style orthographic diagrams on product detail pages. Staggered with <code class="ds-code">.d2</code>, <code class="ds-code">.d3</code>, <code class="ds-code">.d4</code> classes.</p>
        </div>
      </div>
    </section>


    <!-- ── 5. ICONS & DIAGRAMS ──────────────── -->
    <section class="ds-section" id="diagrams">
      <div class="ds-section-header">
        <div class="ds-section-num">01 — Foundations</div>
        <h2 class="ds-section-title">Icons &amp; Diagrams</h2>
        <p class="ds-section-desc">No icon library. All illustration is hand-coded inline SVG following a strict three-layer grammar: <code class="ds-code">.line</code> for primary form, <code class="ds-code">.hair</code> for structure, <code class="ds-code">.signal</code> for the single active element. The same vocabulary scales from a 24px mark to a full-page schematic.</p>
      </div>

      <!-- Mark vocabulary -->
      <div class="ds-specimen">
        <div class="ds-specimen-label">Mark vocabulary — geometric primitives used as icons</div>
        <div class="ds-specimen-canvas" style="padding:0;">
          <div class="ds-marks-row">
