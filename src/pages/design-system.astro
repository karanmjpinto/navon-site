        </div>
      </div>

      <!-- Stroke weight system -->
      <div class="ds-specimen">
        <div class="ds-specimen-label">Stroke weight system — .tech · vector-effect="non-scaling-stroke" mandatory on all elements</div>
        <div class="ds-specimen-canvas">
          <svg viewBox="0 0 540 180" class="tech" xmlns="http://www.w3.org/2000/svg" style="width:100%;">
            <!-- .line — primary structural form -->
            <rect class="line" x="30" y="18" width="180" height="36" vector-effect="non-scaling-stroke"/>
