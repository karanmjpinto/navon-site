            <tr><td>--mid</td><td>#9E9F9B</td><td>Body description text, eyebrow colour</td></tr>
            <tr><td>--light</td><td>#E2E3DE</td><td>Primary body text on dark backgrounds</td></tr>
            <tr><td>--vlight</td><td>#F3F4F4</td><td>Light page section backgrounds</td></tr>
            <tr><td>--paper</td><td>#FFFFFF</td><td>Headlines, active text, light page backgrounds</td></tr>
            <tr><td>--signal</td><td>#E7FF00</td><td>Brand accent — buttons, dots, hovers, selection. Never body text.</td></tr>
            <tr><td>--line</td><td>rgba(255,255,255,0.08)</td><td>Default borders and dividers</td></tr>
            <tr><td>--line-2</td><td>rgba(255,255,255,0.14)</td><td>Active card borders, scrolled nav border</td></tr>
            <tr><td>--font-display</td><td>'Space Grotesk'</td><td>All editorial, display, and body text</td></tr>
            <tr><td>--font-mono</td><td>'JetBrains Mono'</td><td>Labels, eyebrows, specs, wordmark, code</td></tr>
            <tr><td>--nav-h</td><td>68px</td><td>Fixed nav height — used in padding offsets</td></tr>
            <tr><td>--px</td><td>clamp(20px, 4vw, 56px)</td><td>Horizontal page padding on all sections</td></tr>
            <tr><td>--section-y</td><td>clamp(96px, 12vw, 160px)</td><td>Vertical section rhythm (top/bottom padding)</td></tr>
            <tr><td>--easing</td><td>cubic-bezier(0.65, 0, 0.35, 1)</td><td>All transitions across the site</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Colophon -->
      <div class="ds-colophon">
        <div class="dc-left">
          <div class="dc-mark"></div>
          <div>
            <div class="dc-title">Navon Design System</div>
            <div class="dc-meta">v1.1 · June 2026 · Naivasha, Kenya</div>
          </div>
        </div>
        <div class="dc-right">
          <div class="dc-coord">00°42′S 36°26′E</div>
          <a href="/" class="dc-back">← Back to site</a>
        </div>
      </div>
    </section>

  </main>
</div>

<script>
  // Highlight active sidebar link on scroll
  const links = document.querySelectorAll('.ds-nav-group a');
  const sections = document.querySelectorAll('.ds-section, section.ds-section');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        links.forEach(l => {
          l.classList.toggle('active', l.getAttribute('href') === `#${id}`);
        });
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  sections.forEach(s => { if (s.id) observer.observe(s); });

  // Sidebar scroll progress line
  const progressEl = document.getElementById('ds-progress');
  if (progressEl) {
    const update = () => {
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const pct = scrollable > 0 ? Math.min(100, (window.scrollY / scrollable) * 100) : 0;
      progressEl.style.height = pct + '%';
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>

</body>
</html>
