---
import Site from '../layouts/Site.astro';
---
<Site
  title="Navon Futures — Building Africa's deep tech ecosystem"
  description="Navon Futures is our commitment to the full deep tech ecosystem — the capacity, talent and networks built on top of sovereign compute. A rare global network of leading technologists, working with universities, enterprises and governments across Africa."
>

<style>
/* ── Futures page — the ecosystem / capacity-building programme ── */

.fut-hero {
  position: relative;
  padding: calc(var(--nav-h) + 100px) var(--px) 96px;
  border-bottom: 1px solid var(--line);
  overflow: hidden;
}
.fut-hero::before {
  content: "";
  position: absolute; inset: 0;
  background-image:
    linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 56px 56px;
  mask-image: radial-gradient(ellipse at 78% 28%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.3) 60%, transparent 90%);
  -webkit-mask-image: radial-gradient(ellipse at 78% 28%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.3) 60%, transparent 90%);
  pointer-events: none;
}
.fut-hero-inner {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
  gap: 56px;
  align-items: center;
  z-index: 2;
}
@media (max-width: 900px) { .fut-hero-inner { grid-template-columns: 1fr; gap: 32px; } }

.fut-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--mid);
  margin-bottom: 24px;
}
.fut-eyebrow::before {
  content: "";
  width: 8px; height: 8px;
  background: var(--signal);
  display: inline-block;
}
.fut-h1 {
  font-family: var(--font-display);
  font-size: clamp(46px, 6.6vw, 100px);
  line-height: 0.96;
  letter-spacing: -0.04em;
  margin: 0 0 32px;
  font-weight: 500;
}
.fut-h1 em { color: var(--signal); font-style: italic; font-weight: 400; }
.fut-lede {
  font-size: 18px;
  line-height: 1.6;
  color: var(--light);
  max-width: 52ch;
  margin: 0 0 28px;
}
.fut-lede strong { color: var(--paper); font-weight: 500; }
.fut-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

/* ── Pull-quote band ──────────────────────────── */
.fut-quote {
  padding: var(--section-y) var(--px);
  border-bottom: 1px solid var(--line);
}
.fut-quote-inner { max-width: 1000px; }
.fut-quote blockquote {
  margin: 0;
  font-family: var(--font-display);
  font-size: clamp(26px, 3.4vw, 44px);
  line-height: 1.2;
  letter-spacing: -0.025em;
  font-weight: 500;
}
.fut-quote blockquote .accent { color: var(--charcoal); font-style: italic; font-weight: 400; }
.fut-quote .attr {
  margin-top: 28px;
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--slate);
}

/* ── Generic section wrapper ──────────────────── */
.fut-section {
  padding: var(--section-y) var(--px);
  border-bottom: 1px solid var(--line);
}

/* ── Knowledge-partner + expert-domain cards ──── */
.eco-label {
  margin-top: 56px;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--slate);
}
.eco-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
  margin-top: 20px;
}
@media (max-width: 1000px) { .eco-cards { grid-template-columns: 1fr 1fr; } }
@media (max-width: 560px) { .eco-cards { grid-template-columns: 1fr; } }
.eco-card {
  background: var(--ink);
  padding: 32px 26px 36px;
  position: relative;
  transition: background 0.3s ease;
}
.eco-card::before {
  content: "";
  position: absolute; top: 0; left: 0;
  width: 0; height: 2px;
  background: var(--signal);
  transition: width 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
}
.eco-card:hover { background: rgba(231,255,0,0.022); }
.eco-card:hover::before { width: 100%; }
.eco-tag {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--slate);
  margin-bottom: 16px;
}
.eco-card:hover .eco-tag { color: var(--signal); }
.eco-card h4 {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 500;
  letter-spacing: -0.018em;
  margin: 0 0 6px;
  line-height: 1.05;
}
.eco-loc {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.04em;
  color: var(--mid);
  margin-bottom: 16px;
}
.eco-card p {
  color: var(--mid);
  font-size: 14px;
  line-height: 1.6;
  margin: 0;
}
.section--light .eco-cards { background: var(--line); border-color: var(--line); }
.section--light .eco-card { background: rgba(15,17,24,0.015); }
.section--light .eco-card:hover { background: rgba(231,255,0,0.10); }

/* expert domains */
.dom-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
  margin-top: 20px;
}
@media (max-width: 1000px) { .dom-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 560px) { .dom-grid { grid-template-columns: 1fr; } }
.dom {
  background: var(--ink);
  padding: 32px 26px 36px;
}
.dom .d-tag {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--slate);
  margin-bottom: 16px;
}
.dom h4 {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 500;
  letter-spacing: -0.015em;
  margin: 0 0 16px;
  line-height: 1.1;
}
.dom ul { margin: 0; padding: 0; list-style: none; }
.dom li {
  font-size: 13.5px;
  line-height: 1.5;
  color: var(--mid);
  padding: 7px 0 7px 16px;
  position: relative;
  border-top: 1px solid var(--line);
}
.dom li:first-child { border-top: 0; }
.dom li::before {
  content: "›";
  position: absolute; left: 0;
  color: var(--slate);
}

/* ── Audience sub-head (smaller than section-head) ── */
.aud-head {
  max-width: 760px;
  margin-bottom: 8px;
}
.aud-kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--slate);
}
.aud-kicker .accent { color: var(--signal); }
.section--light .aud-kicker .accent { color: var(--charcoal); }

/* ── Audience cards — glyph + index + hover ───── */
.aud-grid {
  display: grid;
  gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
  margin-top: 56px;
}
.aud-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
.aud-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
@media (max-width: 1000px) { .aud-grid.cols-2, .aud-grid.cols-3 { grid-template-columns: 1fr 1fr; } }
@media (max-width: 600px) { .aud-grid.cols-2, .aud-grid.cols-3 { grid-template-columns: 1fr; } }
/* keep dark cards in both dark and light bands for a bold, consistent grid;
   colours are literal so the band's remapped vars can't wash out the title */
.section--light .aud-grid { background: var(--line); border-color: var(--line); }

.aud-card {
  position: relative;
  background: var(--ink);
  padding: 30px 28px 28px;
  min-height: 248px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: background 0.3s ease;
}
.aud-card::before {
  content: "";
  position: absolute; top: 0; left: 0;
  width: 0; height: 2px;
  background: var(--signal);
  transition: width 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
}
.aud-card:hover { background: rgba(231,255,0,0.03); }
.aud-card:hover::before { width: 100%; }

.aud-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26px;
}
.aud-chip {
  width: 46px; height: 46px;
  border: 1px solid rgba(255,255,255,0.14);
  display: flex; align-items: center; justify-content: center;
  color: #7E8194;
  transition: color 0.25s ease, border-color 0.25s ease, background 0.25s ease;
}
.aud-card:hover .aud-chip {
  background: var(--signal);
  border-color: var(--signal);
  color: #0b0b07;
}
.aud-chip svg { width: 23px; height: 23px; display: block; }
.aud-no {
  font-family: var(--font-mono);
  font-size: 28px;
  font-weight: 500;
  letter-spacing: -0.02em;
  line-height: 1;
  color: rgba(255,255,255,0.13);
  transition: color 0.25s ease;
}
.aud-card:hover .aud-no { color: var(--signal); }
.aud-card .aud-kick {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #6F7287;
  margin-bottom: 12px;
}
.aud-card h4 {
  font-family: var(--font-display);
  font-size: 19px;
  font-weight: 500;
  letter-spacing: -0.015em;
  line-height: 1.12;
  color: #FFFFFF;
  margin: 0 0 12px;
}
.aud-card p {
  font-size: 13.5px;
  line-height: 1.6;
  color: #9E9F9B;
  margin: 0;
}
.aud-arrow {
  margin-top: auto;
  align-self: flex-end;
  padding-top: 18px;
  font-size: 16px;
  color: #3F4157;
  opacity: 0;
  transform: translateX(-6px);
  transition: opacity 0.25s ease, transform 0.25s ease, color 0.25s ease;
}
.aud-card:hover .aud-arrow { opacity: 1; transform: translateX(0); color: var(--signal); }

/* ── Mastercard in-practice callout ───────────── */
.mc-callout {
  margin-top: 56px;
  border: 1px solid var(--line);
  background: linear-gradient(135deg, rgba(231,255,0,0.05), rgba(255,255,255,0.012));
  padding: 44px 40px;
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 48px;
  align-items: center;
}
@media (max-width: 820px) { .mc-callout { grid-template-columns: 1fr; gap: 24px; } }
.mc-callout .mc-tag {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--signal);
  margin-bottom: 18px;
}
.mc-callout h3 {
  font-family: var(--font-display);
  font-size: clamp(26px, 3vw, 38px);
  font-weight: 500;
  letter-spacing: -0.025em;
  line-height: 1.08;
  margin: 0 0 16px;
}
.mc-callout h3 em { color: var(--signal); font-style: italic; font-weight: 400; }
.mc-callout p {
  color: var(--mid);
  font-size: 15px;
  line-height: 1.6;
  margin: 0;
  max-width: 48ch;
}
.mc-callout .mc-aside {
  border-left: 1px solid var(--line-2);
  padding-left: 32px;
}
@media (max-width: 820px) { .mc-callout .mc-aside { border-left: 0; border-top: 1px solid var(--line-2); padding-left: 0; padding-top: 24px; } }
.mc-callout .mc-aside p { font-size: 14px; color: var(--light); margin-bottom: 18px; }
.mc-watch {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--mid);
  border-bottom: 1px solid var(--line-2);
  padding-bottom: 4px;
  transition: color 0.2s ease, border-color 0.2s ease;
}
.mc-watch:hover { color: var(--signal); border-color: var(--signal); }

/* ── Partners strip ───────────────────────────── */
.fut-partners {
  padding: 52px var(--px);
  border-bottom: 1px solid var(--line);
}
.partners-strip {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16px 40px;
}
.partners-strip .label {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--slate);
}
.partners-strip .partner-name {
  font-family: var(--font-display);
  font-size: clamp(20px, 2.4vw, 30px);
  font-weight: 500;
  letter-spacing: -0.02em;
  color: var(--light);
  transition: color 0.2s ease;
}
.partners-strip .partner-name:hover { color: var(--signal); }

/* ── Closing CTA ──────────────────────────────── */
.fut-cta {
  padding: var(--section-y) var(--px);
  position: relative;
  overflow: hidden;
}
.fut-cta::before {
  content: "";
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 25% 50%, rgba(231,255,0,0.07), transparent 50%);
  pointer-events: none;
}
.fut-cta-inner {
  position: relative;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 64px;
  align-items: end;
}
@media (max-width: 820px) { .fut-cta-inner { grid-template-columns: 1fr; gap: 32px; } }
.fut-cta h2 {
  font-family: var(--font-display);
  font-size: clamp(40px, 5.2vw, 72px);
  line-height: 1;
  letter-spacing: -0.035em;
  margin: 20px 0 0;
  font-weight: 500;
}
.fut-cta h2 em { color: var(--signal); font-style: italic; font-weight: 400; }
.fut-cta .open-to {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 24px;
}
.fut-cta .open-to span {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--slate);
  border: 1px solid var(--line-2);
  padding: 6px 12px;
}
</style>

<!-- ── HERO ─────────────────────────────────────── -->
<section class="fut-hero">
  <div class="fut-hero-inner">
    <div>
      <div class="fut-eyebrow">Navon Futures</div>
      <h1 class="fut-h1">
        Building the ecosystem.<br/>
        Borderless by design.<br/>
        <em>Built for Africa.</em>
      </h1>
      <p class="fut-lede">
        Navon Futures is our commitment to the full deep tech ecosystem —
        <strong>not a product line, not an add-on.</strong> It is everything that
        comes after the compute: investing in capacity, talent and the utility
        of what we build, and connecting Africa to a rare global network of
        leading technologists.
      </p>
      <div class="fut-ctas">
        <a href="#network" class="cta">Meet the network <span class="arrow">→</span></a>
        <a href="mailto:info@navonworld.com" class="cta-ghost">Be part of it <span class="arrow">→</span></a>
      </div>
    </div>

    <svg viewBox="0 0 480 400" class="tech draw" aria-hidden="true" style="max-width: 480px;">
      <!-- global-network constellation: a central Navon node linked to
           knowledge partners and expert domains around it -->
      <!-- central node -->
      <circle cx="240" cy="200" r="26" fill="#E7FF00" opacity="0.10"/>
      <circle cx="240" cy="200" r="7" class="signal"/>
      <circle cx="240" cy="200" r="7" class="signal">
        <animate attributeName="r" values="7;20;7" dur="3s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="1;0;1" dur="3s" repeatCount="indefinite"/>
      </circle>
      <text x="240" y="244" fill="#FFFFFF" font-size="11" font-family="Space Grotesk" font-weight="500" text-anchor="middle">Navon Futures</text>

      <!-- satellite nodes -->
      <circle cx="80"  cy="80"  r="5" fill="#3F4157"/>
      <text x="80" y="66" fill="#6F7287" font-size="10" font-family="Space Grotesk" text-anchor="middle">UCL</text>
      <circle cx="400" cy="78"  r="5" fill="#3F4157"/>
      <text x="400" y="64" fill="#6F7287" font-size="10" font-family="Space Grotesk" text-anchor="middle">ETH Zürich</text>
      <circle cx="60"  cy="320" r="5" fill="#3F4157"/>
      <text x="60" y="340" fill="#6F7287" font-size="10" font-family="Space Grotesk" text-anchor="middle">UPM</text>
      <circle cx="420" cy="322" r="5" fill="#3F4157"/>
      <text x="420" y="342" fill="#6F7287" font-size="10" font-family="Space Grotesk" text-anchor="middle">UPC</text>
      <circle cx="240" cy="44"  r="4" fill="#3F4157"/>
      <circle cx="446" cy="200" r="4" fill="#3F4157"/>
      <circle cx="34"  cy="200" r="4" fill="#3F4157"/>
      <circle cx="240" cy="360" r="4" fill="#3F4157"/>

      <!-- links -->
      <g class="dashed">
        <line x1="240" y1="200" x2="80"  y2="80"/>
        <line x1="240" y1="200" x2="400" y2="78"/>
        <line x1="240" y1="200" x2="60"  y2="320"/>
        <line x1="240" y1="200" x2="420" y2="322"/>
        <line x1="240" y1="200" x2="240" y2="44"/>
        <line x1="240" y1="200" x2="446" y2="200"/>
        <line x1="240" y1="200" x2="34"  y2="200"/>
        <line x1="240" y1="200" x2="240" y2="360"/>
      </g>

      <!-- legend -->
      <circle cx="32" cy="388" r="4" class="signal"/>
      <text x="42" y="392" class="label-signal" font-size="9" letter-spacing="1.5">NAVON</text>
      <circle cx="150" cy="388" r="4" fill="#3F4157"/>
      <text x="160" y="392" fill="#6F7287" font-size="9" letter-spacing="1.5">GLOBAL NETWORK</text>
    </svg>
  </div>
</section>

<!-- ── PULL QUOTE ───────────────────────────────── -->
<section class="fut-quote section--light">
  <div class="fut-quote-inner reveal">
    <blockquote>
      Africa does not have a shortage of ambition, talent, or ideas. It has a
      shortage of the <span class="accent">infrastructure, networks, and
      pathways</span> needed to turn those things into products, policies, and
      industries. Navon Futures is our response to that gap — and our
      responsibility to close it.
    </blockquote>
    <div class="attr">— Navon, on our commitment to the ecosystem</div>
  </div>
</section>

<!-- ── OUR GLOBAL NETWORK ───────────────────────── -->
<section class="fut-section" id="network">
  <div class="section-head" style="padding-top:0;">
    <div>
      <div class="eyebrow"><span class="mark"></span>Our global network</div>
      <h2 class="section-title reveal">The people behind<br/><span class="accent">Navon Futures.</span></h2>
    </div>
    <p class="section-lede reveal d1">
      Navon Futures convenes world-leading technologists across artificial
      intelligence, quantum computing, cybersecurity and sovereign
      infrastructure — and brings that expertise directly to Africa.
    </p>
  </div>

  <div class="eco-label reveal">Global knowledge partners · working relationships, not affiliations</div>
  <div class="eco-cards">
    <div class="eco-card reveal d1">
      <div class="eco-tag">Partner · 01</div>
      <h4>UCL.</h4>
      <div class="eco-loc">University College London</div>
      <p>AI, computer science and data systems — guest expertise, knowledge transfer and research collaboration.</p>
    </div>
    <div class="eco-card reveal d2">
      <div class="eco-tag">Partner · 02</div>
      <h4>ETH Zürich.</h4>
      <div class="eco-loc">Eidgenössische Technische Hochschule</div>
      <p>Advanced computing, engineering simulation and robotics — applied to real deep tech problems.</p>
    </div>
    <div class="eco-card reveal d3">
      <div class="eco-tag">Partner · 03</div>
      <h4>UPM.</h4>
      <div class="eco-loc">Universidad Politécnica de Madrid</div>
      <p>Telecommunications, systems engineering and large-scale infrastructure design.</p>
    </div>
    <div class="eco-card reveal d4">
      <div class="eco-tag">Partner · 04</div>
      <h4>UPC.</h4>
      <div class="eco-loc">Universitat Politècnica de Catalunya</div>
      <p>Quantum computing, data science and advanced networking — active in Navon's quantum research.</p>
    </div>
  </div>

  <div class="sub-head" style="margin-top:64px;">
    <div class="eyebrow"><span class="mark"></span>Expert domains</div>
    <h3 style="font-family:var(--font-display); font-size:clamp(28px,3.4vw,44px); font-weight:500; letter-spacing:-0.03em; line-height:1.05; margin:14px 0 0;">Where the network <span class="accent" style="color:var(--signal); font-style:italic; font-weight:400;">goes deep.</span></h3>
  </div>

  <div class="dom-grid">
    <div class="dom reveal d1">
      <div class="d-tag">Domain · 01</div>
      <h4>Artificial intelligence.</h4>
      <ul>
        <li>LLM training &amp; fine-tuning</li>
        <li>NLP for African languages</li>
        <li>Computer vision</li>
        <li>Responsible AI deployment</li>
        <li>ML infrastructure at scale</li>
      </ul>
    </div>
    <div class="dom reveal d2">
      <div class="d-tag">Domain · 02</div>
      <h4>Quantum computing.</h4>
      <ul>
        <li>Quantum circuit design</li>
        <li>Hybrid classical-quantum algorithms</li>
        <li>Post-quantum cryptography</li>
        <li>Quantum key distribution (QKD)</li>
      </ul>
    </div>
    <div class="dom reveal d3">
      <div class="d-tag">Domain · 03</div>
      <h4>Cybersecurity.</h4>
      <ul>
        <li>Sovereign cloud security</li>
        <li>Zero-trust network design</li>
        <li>Quantum-safe frameworks</li>
        <li>Infrastructure hardening</li>
      </ul>
    </div>
    <div class="dom reveal d4">
      <div class="d-tag">Domain · 04</div>
      <h4>Deep tech infrastructure.</h4>
      <ul>
