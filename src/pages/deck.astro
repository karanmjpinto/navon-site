          <div class="reveal d1">
            <p class="deck-kicker">Risks &amp; mitigations</p>
            <div class="card-grid cols-1" style="grid-template-columns:1fr">
              <div class="gcard" style="min-height:auto"><div class="gcard-top"><div class="gnum">01</div><Icon name="clock" class="gicon" /></div><div class="gtitle">Deployment delay</div><div class="gbody" style="margin-top:6px">Delta LOI secures modular enclosure supply.</div></div>
              <div class="gcard" style="min-height:auto"><div class="gcard-top"><div class="gnum">02</div><Icon name="users" class="gicon" /></div><div class="gtitle">Customer conversion</div><div class="gbody" style="margin-top:6px">30 racks already confirmed against pipeline.</div></div>
              <div class="gcard" style="min-height:auto"><div class="gcard-top"><div class="gnum">03</div><Icon name="coins" class="gicon" /></div><div class="gtitle">FX exposure</div><div class="gbody" style="margin-top:6px">USD revenue with local KCB debt as a natural hedge.</div></div>
