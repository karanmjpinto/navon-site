              <div class="row"><span class="name">Security</span><span class="track"><span class="fl" style="width:3%"></span></span><span class="amt">$0.1M</span></div>
              <div class="row"><span class="name">Logistics</span><span class="track"><span class="fl" style="width:3%"></span></span><span class="amt">$0.1M</span></div>
              <div class="row"><span class="name">Land &amp; water</span><span class="track"><span class="fl" style="width:3%"></span></span><span class="amt">$0.1M</span></div>
            </div>
