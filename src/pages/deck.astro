        <div class="returns-grid">
          <div class="rc reveal"><div class="v">$4.39M</div><div class="k">ARR by Year 2</div></div>
          <div class="rc reveal d1"><div class="v">$3.46M</div><div class="k">EBITDA — 75% margin</div></div>
          <div class="rc reveal d2"><div class="v"><span class="signal">47%</span></div><div class="k">Leveraged IRR</div></div>
          <div class="rc reveal d3"><div class="v">$6.4M</div><div class="k">Project NPV</div></div>
