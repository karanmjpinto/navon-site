  <script is:inline define:vars={{ accessCode: 'navon2026' }}>
    (function () {
      const gate = document.getElementById('gate');
      const deck = document.getElementById('deck');
      const form = document.getElementById('gate-form');
      const input = document.getElementById('gate-input');
      const msg = document.getElementById('gate-msg');
      const KEY = 'navon-deck-unlocked';

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const NUM_RE = /^(\D*)(\d[\d,]*(?:\.\d+)?)(.*)$/;

      // Count a single stat value up from 0 to its printed number, preserving
      // any prefix ($, ~, >), suffix (%, ×, MW, B…), decimals and thousands commas.
      function countUp(host) {
        if (!host || host.dataset.counted) return;
        host.dataset.counted = '1';
        const raw = host.textContent.trim();
        const m = raw.match(NUM_RE);
        if (!m) return;                       // non-numeric (e.g. "Kenya")
        const [, prefix, numStr, suffix] = m;
        const decimals = numStr.includes('.') ? numStr.split('.')[1].length : 0;
        const hasComma = numStr.includes(',');
        const target = parseFloat(numStr.replace(/,/g, ''));
        if (prefersReduced || !target) return;
        const fmt = (n) => {
          let s = n.toFixed(decimals);
          if (hasComma) {
            const [int, dec] = s.split('.');
            s = int.replace(/\B(?=(\d{3})+(?!\d))/g, ',') + (dec ? '.' + dec : '');
          }
          return s;
        };
        const DUR = 1100, t0 = performance.now();
        const tick = (now) => {
          const p = Math.min((now - t0) / DUR, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          host.textContent = prefix + fmt(target * eased) + suffix;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }

      // Pick the value-bearing node inside a revealed stat block, then count it.
      function runCount(el) {
        if (el.classList.contains('big')) { countUp(el.querySelector('.signal') || el); return; }
        const v = el.querySelector('.v');
        if (v) countUp(v.querySelector('.signal') || v);
      }

      let observer = null;
      function startReveal() {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); runCount(e.target); io.unobserve(e.target); } });
        }, { threshold: 0.12 });
        deck.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      }

      function startSpy() {
        const links = Array.from(document.querySelectorAll('#deck-nav-links a[data-spy]'));
        const map = new Map(links.map((a) => [a.dataset.spy, a]));
        const spy = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              links.forEach((l) => l.classList.remove('active'));
              const a = map.get(e.target.id);
              if (a) { a.classList.add('active'); a.scrollIntoView({ inline: 'center', block: 'nearest' }); }
            }
          });
        }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
        document.querySelectorAll('.slide[id]').forEach((s) => { if (map.has(s.id)) spy.observe(s); });

        const progress = document.getElementById('deck-progress');
        const onScroll = () => {
          const h = document.documentElement.scrollHeight - window.innerHeight;
          progress.style.width = (h > 0 ? (window.scrollY / h) * 100 : 0) + '%';
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      function unlock() {
        gate.hidden = true;
        deck.hidden = false;
        document.body.style.overflow = '';
        startReveal();
        startSpy();
      }

      // lock scroll behind gate
      document.body.style.overflow = 'hidden';

      if (sessionStorage.getItem(KEY) === '1') { unlock(); }

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (input.value.trim().toLowerCase() === accessCode) {
          sessionStorage.setItem(KEY, '1');
          unlock();
        } else {
          gate.classList.add('is-error');
          msg.textContent = 'Incorrect code — try again';
          input.value = '';
          input.focus();
        }
      });
    })();
  </script>
</body>
