---
// Line-icon set for the investor deck. Single source of truth: add a path
// string to `P` and reference it by name. Matches the deck's SVG idiom
// (24×24, 1.5 stroke, currentColor) so icons inherit theme colour.
interface Props { name: string; class?: string; }
const { name, class: className = '' } = Astro.props;

const P: Record<string, string> = {
  spark:  '<path d="M12 3v3M12 18v3M3 12h3M18 12h3"/><path d="M12 7.5c.6 2.4 2.1 3.9 4.5 4.5-2.4.6-3.9 2.1-4.5 4.5-.6-2.4-2.1-3.9-4.5-4.5 2.4-.6 3.9-2.1 4.5-4.5z"/>',
  doc:    '<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 17h4"/>',
  flag:   '<path d="M5 21V4"/><path d="M5 4h11l-2 4 2 4H5"/>',
  alert:  '<path d="M12 3 2 20h20z"/><path d="M12 10v4"/><path d="M12 17.5h.01"/>',
  target: '<circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="4"/>',
  clock:  '<circle cx="12" cy="12" r="8"/><path d="M12 8v4l3 2"/>',
  layers: '<path d="M12 3 3 8l9 5 9-5z"/><path d="M3 13l9 5 9-5"/>',
  shield: '<path d="M12 3l7 3v5c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V6z"/><path d="M9.2 12l2 2 3.6-4"/>',
  coins:  '<circle cx="12" cy="12" r="8"/><path d="M12 7.3v9.4M14.4 9.4C14.4 8.4 13.1 8 12 8s-2.4.5-2.4 1.9 1.5 1.7 2.4 1.9 2.6.6 2.6 2-1.3 1.9-2.6 1.9-2.6-.6-2.6-1.6"/>',
  pin:    '<path d="M12 21s-6-5.5-6-10a6 6 0 0 1 12 0c0 4.5-6 10-6 10z"/><circle cx="12" cy="11" r="2.4"/>',
  trend:  '<path d="M4 17l5-5 3 3 8-8"/><path d="M16 7h4v4"/>',
  gem:    '<path d="M6 4h12l3 5-9 11L3 9z"/><path d="M3 9h18M9 4 7 9l5 11 5-11-2-5"/>',
  check:  '<circle cx="12" cy="12" r="9"/><path d="M8.4 12.4l2.3 2.3 4.9-4.9"/>',
  bolt:   '<path d="M13 3 5 13h6l-1 8 8-11h-6z"/>',
  users:  '<circle cx="9" cy="8" r="3"/><path d="M3.5 20a5.5 5.5 0 0 1 11 0"/><path d="M16 5.4a3 3 0 0 1 0 5.2"/><path d="M17.5 14.3A5.5 5.5 0 0 1 21 20"/>',
  server: '<rect x="4" y="4" width="16" height="6.5" rx="1.2"/><rect x="4" y="13.5" width="16" height="6.5" rx="1.2"/><path d="M7.5 7.2h.01M7.5 16.7h.01"/>',
  cloud:  '<path d="M7.5 18a4.2 4.2 0 0 1-.4-8.4 5 5 0 0 1 9.5-1.3A3.7 3.7 0 0 1 16.8 18z"/>',
  lock:   '<rect x="5" y="11" width="14" height="9" rx="1.5"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/><path d="M12 15v2.2"/>',
  code:   '<path d="M9 8l-4 4 4 4"/><path d="M15 8l4 4-4 4"/>',
  cpu:    '<rect x="6" y="6" width="12" height="12" rx="1.5"/><rect x="9.5" y="9.5" width="5" height="5" rx="0.6"/><path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"/>',
  leaf:   '<path d="M5 19c0-8 6-13 14-13 0 8-5 14-13 14a6 6 0 0 1-1-1z"/><path d="M5 19c3-4 6-6.5 10-7.5"/>',
  globe:  '<circle cx="12" cy="12" r="8.5"/><path d="M3.5 12h17"/><path d="M12 3.5c2.6 2.6 2.6 14.4 0 17M12 3.5c-2.6 2.6-2.6 14.4 0 17"/>',
};
const inner = P[name] ?? P.spark;
---
<svg class={`dicon ${className}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={inner}></svg>
