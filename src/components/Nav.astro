        </div>
      </div>

    </div>
    <a class="nav-signin" href="https://portal.navon.africa/login">Sign in</a>
    <a href="/about.html#contact" class="cta">Talk to us <span class="arrow">→</span></a>
    <button class="nav-burger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="nav-mobile">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

