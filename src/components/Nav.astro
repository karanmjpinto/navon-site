---
// Single-source-of-truth nav. Edit here once and every page that uses
// the Site layout picks up the change. Absolute paths so this works
// from any URL depth (e.g. /legal/privacy-policy).
import { Image } from 'astro:assets';
import wordmarkWhite from '../assets/navon-wordmark-white.png';
import wordmarkBlack from '../assets/navon-wordmark-black.png';
---
<nav class="nav">
  <a href="/index.html" class="wordmark" aria-label="Navon home">
    <Image class="wm-img wm-dark" src={wordmarkWhite} alt="Navon" width={420} />
    <Image class="wm-img wm-light" src={wordmarkBlack} alt="Navon" width={420} />
  </a>
  <div class="nav-right">
    <div class="nav-menu">

      <!-- Products -->
      <div class="has-dropdown">
        <a href="/products.html">Products <span class="chev">▾</span></a>
        <div class="mega-menu">
          <div class="mega-menu-inner cols-5">
            <a class="mega-menu-card" href="/products.html#modular">
              <div class="num">01</div><div class="name">Modular DCs</div>
            </a>
            <a class="mega-menu-card" href="/products.html#turnkey">
              <div class="num">02</div><div class="name">Turnkey Hardware Systems</div>
            </a>
            <a class="mega-menu-card" href="/cloud.html">
              <div class="num">03</div><div class="name">Sovereign Cloud</div>
            </a>
            <a class="mega-menu-card" href="/products.html#security">
              <div class="num">04</div><div class="name">Cybersecurity</div>
            </a>
            <a class="mega-menu-card" href="/products.html#utility">
              <div class="num">05</div><div class="name">Utility</div>
            </a>
          </div>
        </div>
      </div>

      <!-- Missions -->
      <a href="/missions.html">Missions</a>

      <!-- Deployments -->
      <a href="/hells-gate.html">Deployments</a>

      <!-- Partners -->
      <a href="/partners.html">Partners</a>

      <!-- Resources -->
      <div class="has-dropdown">
        <a href="/resources.html">Resources <span class="chev">▾</span></a>
        <div class="mega-menu">
          <div class="mega-menu-inner cols-2">
            <div class="mega-menu-col">
              <h5>Library</h5>
              <a class="link" href="/resources.html">Overview <span class="arrow">→</span></a>
              <a class="link" href="/insights.html">Insights <span class="arrow">→</span></a>
              <a class="link" href="/news.html">News <span class="arrow">→</span></a>
              <a class="link" href="/faq.html">FAQ <span class="arrow">→</span></a>
              <a class="link" href="/docs.html">Docs <span class="arrow">→</span></a>
            </div>
            <div class="mega-menu-col">
              <h5>Tools</h5>
              <a class="link" href="/tools.html">Tools overview <span class="arrow">→</span></a>
              <a class="link" href="/customer-portal.html">Customer Portal <span class="arrow">→</span></a>
            </div>
          </div>
        </div>
      </div>

      <!-- Company -->
      <div class="has-dropdown">
        <a href="/about.html">Company <span class="chev">▾</span></a>
        <div class="mega-menu">
          <div class="mega-menu-inner cols-2">
            <div class="mega-menu-col">
              <h5>Company</h5>
              <a class="link" href="/vision.html">Vision <span class="arrow">→</span></a>
              <a class="link" href="/about.html">Thesis <span class="arrow">→</span></a>
              <a class="link" href="/inside.html">Team <span class="arrow">→</span></a>
            </div>
            <div class="mega-menu-col">
              <h5>Programme</h5>
              <a class="link" href="/futures.html">Navon Futures <span class="arrow">→</span></a>
            </div>
